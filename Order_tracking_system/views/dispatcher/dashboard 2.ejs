<%- include('../partials/header') %>
<script src="https://cdn.jsdelivr.net/npm/react@18/umd/react.development.js"></script>
<script src="https://cdn.jsdelivr.net/npm/react-dom@18/umd/react-dom.development.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@babel/standalone/babel.min.js"></script>

<nav aria-label="breadcrumb" class="mb-3">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
    <li class="breadcrumb-item active">Dispatch Dashboard</li>
  </ol>
</nav>

<div id="app-root"></div>

<script type="text/babel">
const { useState, useEffect, useCallback } = React;

const STATUS_CONFIG = {
  ORDER_PLACED: { text: 'Order Placed', icon: '🕐', bg: '#fd7e14', tc: '#fff' },
  ACCEPTED:     { text: 'Accepted',     icon: '✅', bg: '#0dcaf0', tc: '#000' },
  DISPATCHED:   { text: 'Dispatched',   icon: '🚛', bg: '#198754', tc: '#fff' },
  ON_HOLD:      { text: 'On Hold',      icon: '⏸️', bg: '#e57373', tc: '#fff' },
};

function fmt(value) {
  if (!value) return '—';
  const dt = new Date(value);
  if (isNaN(dt.getTime())) return value;
  return new Intl.DateTimeFormat('en-IN', {
    day: '2-digit', month: 'short', year: 'numeric',
    hour: '2-digit', minute: '2-digit', hour12: true,
  }).format(dt);
}

function StatusBadge({ status }) {
  const cfg = STATUS_CONFIG[status] || { bg: '#6c757d', tc: '#fff', text: status, icon: '' };
  return (
    <span className="badge" style={{ background: cfg.bg, color: cfg.tc }}>
      {cfg.icon} {cfg.text}
    </span>
  );
}

function Toast({ msg, type, onClose }) {
  useEffect(() => {
    const t = setTimeout(onClose, 4000);
    return () => clearTimeout(t);
  }, []);
  return (
    <div style={{
      position: 'fixed', top: 80, right: 20, zIndex: 9999, minWidth: 280,
      background: type === 'success' ? '#198754' : '#dc3545',
      color: '#fff', padding: '12px 18px', borderRadius: 8,
      boxShadow: '0 4px 16px rgba(0,0,0,.25)'
    }}>
      {type === 'success' ? '✅' : '❌'} {msg}
    </div>
  );
}

function DispatchModal({ order, loadingLocations, onSubmit, onClose }) {
  const [form, setForm] = useState({
    vehicle_number: '',
    driver_name: '',
    driver_phone: '',
    bilty_number: '',
    actual_loading_location_code: '',
  });
  const [saving, setSaving] = useState(false);
  const [err, setErr]       = useState('');

  const set = (k, v) => setForm(f => ({ ...f, [k]: v }));

  const submit = async () => {
    if (!form.vehicle_number.trim())                return setErr('Vehicle number is required');
    if (!form.driver_phone.trim())                  return setErr('Driver phone is required');
    if (!/^\d{10}$/.test(form.driver_phone.trim())) return setErr('Driver phone must be exactly 10 digits');
    if (!form.bilty_number.trim())                  return setErr('Bilty number is required');
    if (!form.actual_loading_location_code)         return setErr('Actual loading location is required');
    setErr('');
    setSaving(true);
    await onSubmit(order.order_id, form);
    setSaving(false);
  };

  return (
    <div className="modal d-block" tabIndex="-1" style={{ background: 'rgba(0,0,0,0.55)' }}>
      <div className="modal-dialog modal-dialog-centered modal-lg">
        <div className="modal-content">

          <div className="modal-header" style={{ background: '#198754', color: '#fff' }}>
            <h5 className="modal-title">🚛 Dispatch — Order #{order.order_id}</h5>
            <button type="button" className="btn-close btn-close-white" onClick={onClose}></button>
          </div>

          <div className="modal-body">
            {/* Order summary */}
            <div className="row g-2 mb-4 p-3 rounded" style={{ background: '#f8faff' }}>
              <div className="col-6 col-md-4">
                <div className="text-muted small">Dealer</div>
                <div className="fw-semibold">{order.dealer_login_name || order.dealer_company_name || order.dealer_name}</div>
              </div>
              <div className="col-6 col-md-4">
                <div className="text-muted small">Order Time</div>
                <div className="fw-semibold" style={{ fontSize: '.85rem' }}>{fmt(order.order_date)}</div>
              </div>
              {/* Products & Quantities */}
              {(() => {
                const items = parseItems(order);
                const total = items.reduce((s, i) => s + parseFloat(i.order_quantity || 0), 0);
                if (items.length > 1) {
                  return (
                    <div className="col-12">
                      <div className="text-muted small mb-1 fw-semibold">Products &amp; Quantities</div>
                      <table className="table table-sm table-bordered mb-0" style={{ fontSize: '.85rem', background: '#fff' }}>
                        <thead className="table-light">
                          <tr><th>Product</th><th style={{ width: 80 }}>Bags</th><th style={{ width: 100 }}>Qty (MT)</th></tr>
                        </thead>
                        <tbody>
                          {items.map((item, idx) => (
                            <tr key={idx}>
                              <td>{item.product_name || `#${item.product_id}`}</td>
                              <td>{item.order_bags || '—'}</td>
                              <td>{parseFloat(item.order_quantity).toFixed(3)}</td>
                            </tr>
                          ))}
                        </tbody>
                        <tfoot>
                          <tr className="table-secondary fw-bold">
                            <td colSpan={2} className="text-muted small">Total</td>
                            <td>{total.toFixed(3)}</td>
                          </tr>
                        </tfoot>
                      </table>
                    </div>
                  );
                }
                const single = items[0];
                return (
                  <>
                    <div className="col-6 col-md-4">
                      <div className="text-muted small">Product</div>
                      <div className="fw-semibold">{single ? (single.product_name || `#${single.product_id}`) : '—'}</div>
                    </div>
                    <div className="col-6 col-md-4">
                      <div className="text-muted small">Quantity</div>
                      <div className="fw-semibold">{single ? parseFloat(single.order_quantity).toFixed(3) : (order.order_quantity || '—')} MT</div>
                    </div>
                    {single && single.order_bags && (
                      <div className="col-6 col-md-4">
                        <div className="text-muted small">No. of Bags</div>
                        <div className="fw-semibold">{single.order_bags}</div>
                      </div>
                    )}
                  </>
                );
              })()}
              <div className="col-6 col-md-4">
                <div className="text-muted small">Party</div>
                <div className="fw-semibold">{order.party_company_name || order.party_name_col || '—'}</div>
              </div>
              <div className="col-6 col-md-4">
                <div className="text-muted small">Delivery Address</div>
                <div className="fw-semibold">{order.party_address || '—'}</div>
              </div>
              <div className="col-6 col-md-4">
                <div className="text-muted small">Party Phone</div>
                <div className="fw-semibold">
                  {order.party_phone
                    ? <a href={`tel:${order.party_phone}`}>{order.party_phone}</a>
                    : '—'}
                </div>
              </div>
              <div className="col-6 col-md-6">
                <div className="text-muted small">Load Type</div>
                <div className="fw-semibold">{order.load_type_desc || order.load_type_code || '—'}</div>
              </div>
              <div className="col-6 col-md-6">
                <div className="text-muted small">Preferred Loading Location</div>
                <div className="fw-semibold">{order.preferred_location_desc || order.preferred_location_code || '—'}</div>
              </div>
            </div>

            {/* Dispatch form */}
            <h6 className="fw-bold text-muted text-uppercase small mb-3">Enter Dispatch Details</h6>
            {err && <div className="alert alert-danger py-2 mb-3">{err}</div>}

            <div className="row g-3">
              <div className="col-md-6">
                <label className="form-label fw-semibold">
                  Vehicle Number <span className="text-danger">*</span>
                </label>
                <input
                  className="form-control text-uppercase"
                  placeholder="e.g. UP32AB1234"
                  value={form.vehicle_number}
                  onChange={e => set('vehicle_number', e.target.value.toUpperCase())}
                />
              </div>
              <div className="col-md-6">
                <label className="form-label fw-semibold">
                  Bilty Number <span className="text-danger">*</span>
                </label>
                <input
                  className="form-control"
                  placeholder="Transport receipt / bilty number"
                  value={form.bilty_number}
                  onChange={e => set('bilty_number', e.target.value)}
                />
              </div>
              <div className="col-md-6">
                <label className="form-label fw-semibold">Driver Name</label>
                <input
                  className="form-control"
                  placeholder="Driver full name (optional)"
                  value={form.driver_name}
                  onChange={e => set('driver_name', e.target.value)}
                />
              </div>
              <div className="col-md-6">
                <label className="form-label fw-semibold">
                  Driver Phone <span className="text-danger">*</span>
                </label>
                <input
                  className="form-control"
                  placeholder="10-digit mobile number"
                  maxLength={10}
                  value={form.driver_phone}
                  onChange={e => set('driver_phone', e.target.value.replace(/\D/g, ''))}
                />
              </div>
              <div className="col-12">
                <label className="form-label fw-semibold">
                  Actual Loading Location <span className="text-danger">*</span>
                </label>
                <select
                  className="form-select"
                  value={form.actual_loading_location_code}
                  onChange={e => set('actual_loading_location_code', e.target.value)}
                >
                  <option value="">-- Select Actual Loading Location --</option>
                  {loadingLocations.map(l => (
                    <option key={l.code} value={l.code}>
                      {l.code_label || l.code_desc || l.code}
                    </option>
                  ))}
                </select>
              </div>
            </div>
          </div>

          <div className="modal-footer">
            <button className="btn btn-secondary" onClick={onClose}>Cancel</button>
            <button className="btn btn-success" disabled={saving} onClick={submit}>
              {saving && <span className="spinner-border spinner-border-sm me-1"></span>}
              🚛 Confirm Dispatch
            </button>
          </div>

        </div>
      </div>
    </div>
  );
}

function parseItems(order) {
  const raw = order.items;
  if (!raw) return [];
  const arr = typeof raw === 'string' ? JSON.parse(raw) : raw;
  return Array.isArray(arr) ? arr.filter(i => i && i.product_id) : [];
}

function ItemsCell({ order }) {
  const items = parseItems(order);
  if (items.length === 0) return <span className="text-muted">—</span>;
  if (items.length === 1) return <span>{items[0].product_name || `#${items[0].product_id}`}</span>;
  return (
    <span>
      {items[0].product_name || `#${items[0].product_id}`}
      <span className="badge bg-secondary ms-1" style={{ fontSize: '.7rem' }}>+{items.length - 1}</span>
    </span>
  );
}

function QtyCell({ order }) {
  const items = parseItems(order);
  const total = items.reduce((s, i) => s + parseFloat(i.order_quantity || 0), 0);
  const display = total > 0 ? total : parseFloat(order.order_quantity || 0);
  return <span>{display % 1 === 0 ? display : display.toFixed(3)} MT</span>;
}

function OrderRow({ order, onAccept, onDispatch }) {
  const [accepting, setAccepting] = useState(false);

  const handleAccept = async () => {
    setAccepting(true);
    await onAccept(order.order_id);
    setAccepting(false);
  };

  return (
    <tr>
      <td className="fw-semibold text-nowrap">#{order.order_id}</td>
      <td className="text-nowrap" style={{ fontSize: '.8rem' }}>{fmt(order.order_date)}</td>
      <td><ItemsCell order={order} /></td>
      <td className="text-nowrap"><QtyCell order={order} /></td>
      <td>{order.party_company_name || order.party_name_col || '—'}</td>
      <td className="d-none d-lg-table-cell" style={{ maxWidth: 160, overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }}>
        {order.party_address || '—'}
      </td>
      <td className="d-none d-md-table-cell text-nowrap">
        {order.party_phone
          ? <a href={`tel:${order.party_phone}`}>{order.party_phone}</a>
          : '—'}
      </td>
      <td className="d-none d-xl-table-cell">{order.load_type_desc || order.load_type_code || '—'}</td>
      <td className="d-none d-xl-table-cell">{order.preferred_location_desc || order.preferred_location_code || '—'}</td>
      <td><StatusBadge status={order.order_status} /></td>
      <td className="text-nowrap">
        {order.order_status === 'ORDER_PLACED' && (
          <button className="btn btn-sm btn-outline-info" disabled={accepting} onClick={handleAccept}>
            {accepting
              ? <span className="spinner-border spinner-border-sm"></span>
              : '✅ Accept'}
          </button>
        )}
        {order.order_status === 'ACCEPTED' && (
          <button className="btn btn-sm btn-success" onClick={() => onDispatch(order)}>
            🚛 Dispatch
          </button>
        )}
        {order.order_status === 'DISPATCHED' && (
          <div style={{ fontSize: '.8rem' }}>
            {order.dispatch_vehicle_number && <div className="text-muted">🚗 {order.dispatch_vehicle_number}</div>}
            {order.driver_phone && (
              <a href={`tel:${order.driver_phone}`} className="d-block">📞 {order.driver_phone}</a>
            )}
          </div>
        )}
        {order.order_status === 'ON_HOLD' && (
          <span className="text-muted small">—</span>
        )}
      </td>
    </tr>
  );
}

function DealerGroup({ orders, onAccept, onDispatch }) {
  const [expanded, setExpanded] = useState(true);

  const placedCount    = orders.filter(o => o.order_status === 'ORDER_PLACED').length;
  const acceptedCount  = orders.filter(o => o.order_status === 'ACCEPTED').length;
  const onHoldCount    = orders.filter(o => o.order_status === 'ON_HOLD').length;
  const dispatchedCount = orders.filter(o => o.order_status === 'DISPATCHED').length;

  const first       = orders[0];
  const displayName = first.dealer_login_name || first.dealer_company_name || first.dealer_name || `Dealer #${first.dealer_id}`;
  const subName     = (first.dealer_company_name && first.dealer_login_name && first.dealer_company_name !== first.dealer_login_name)
    ? first.dealer_company_name
    : null;

  return (
    <div className="card mb-3 shadow-sm">
      <div
        className="card-header d-flex align-items-center justify-content-between"
        style={{ cursor: 'pointer', background: '#f0f4ff', borderBottom: '2px solid #dee2e6' }}
        onClick={() => setExpanded(e => !e)}
      >
        <div className="d-flex align-items-center gap-2">
          <span style={{ fontSize: '1.2rem' }}>🏬</span>
          <div>
            <span className="fw-bold">{displayName}</span>
            {subName && <span className="text-muted ms-2 small">{subName}</span>}
          </div>
        </div>
        <div className="d-flex align-items-center gap-2 flex-wrap">
          {placedCount    > 0 && <span className="badge" style={{ background: '#fd7e14', color: '#fff' }}>🕐 {placedCount} Placed</span>}
          {acceptedCount  > 0 && <span className="badge" style={{ background: '#0dcaf0', color: '#000' }}>✅ {acceptedCount} Accepted</span>}
          {onHoldCount    > 0 && <span className="badge" style={{ background: '#e57373', color: '#fff' }}>⏸️ {onHoldCount} On Hold</span>}
          {dispatchedCount > 0 && <span className="badge" style={{ background: '#198754', color: '#fff' }}>🚛 {dispatchedCount} Dispatched</span>}
          <span className="text-muted ms-1">{expanded ? '▲' : '▼'}</span>
        </div>
      </div>

      {expanded && (
        <div className="card-body p-0">
          <div className="table-responsive">
            <table className="table table-hover table-sm mb-0" style={{ fontSize: '.87rem' }}>
              <thead className="table-light">
                <tr>
                  <th>Order#</th>
                  <th>Time</th>
                  <th>Product</th>
                  <th>Qty</th>
                  <th>Party</th>
                  <th className="d-none d-lg-table-cell">Address</th>
                  <th className="d-none d-md-table-cell">Contact</th>
                  <th className="d-none d-xl-table-cell">Load Type</th>
                  <th className="d-none d-xl-table-cell">Pref. Location</th>
                  <th>Status</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                {orders.map(o => (
                  <OrderRow
                    key={o.order_id}
                    order={o}
                    onAccept={onAccept}
                    onDispatch={onDispatch}
                  />
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )}
    </div>
  );
}

function App() {
  const [orders,          setOrders]          = useState([]);
  const [loading,         setLoading]         = useState(true);
  const [showOnHold,      setShowOnHold]      = useState(false);
  const [showDispatched,  setShowDispatched]  = useState(false);
  const [dispatchModal,   setDispatchModal]   = useState(null);
  const [loadingLocs,     setLoadingLocs]     = useState([]);
  const [toast,           setToast]           = useState(null);

  const notify = (msg, type = 'success') => setToast({ msg, type });

  const fetchOrders = useCallback(async () => {
    setLoading(true);
    const statuses = ['ORDER_PLACED', 'ACCEPTED'];
    if (showOnHold)     statuses.push('ON_HOLD');
    if (showDispatched) statuses.push('DISPATCHED');
    try {
      const r    = await fetch(`/api/dispatcher/orders?statuses=${statuses.join(',')}`);
      const data = await r.json();
      setOrders(Array.isArray(data) ? data : []);
    } catch {
      notify('Failed to load orders', 'error');
    }
    setLoading(false);
  }, [showOnHold, showDispatched]);

  useEffect(() => { fetchOrders(); }, [fetchOrders]);

  useEffect(() => {
    fetch('/api/codes/loading_location')
      .then(r => r.json())
      .then(d => setLoadingLocs(Array.isArray(d) ? d : []))
      .catch(() => {});
  }, []);

  const handleAccept = async (orderId) => {
    const r = await fetch(`/api/dispatcher/orders/${orderId}/accept`, { method: 'POST' });
    if (r.ok) {
      notify(`Order #${orderId} accepted`);
      fetchOrders();
    } else {
      const d = await r.json().catch(() => ({}));
      notify(d.error || 'Failed to accept order', 'error');
    }
  };

  const handleDispatch = async (orderId, form) => {
    const r = await fetch(`/api/dispatcher/orders/${orderId}/dispatch`, {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify(form),
    });
    if (r.ok) {
      notify(`Order #${orderId} dispatched successfully`);
      setDispatchModal(null);
      fetchOrders();
    } else {
      const d = await r.json().catch(() => ({}));
      notify(d.error || 'Failed to dispatch', 'error');
    }
  };

  // Group by dealer_id, preserve insertion order (already sorted by dealer_id, order_date ASC from API)
  const dealerGroups = {};
  orders.forEach(o => {
    if (!dealerGroups[o.dealer_id]) dealerGroups[o.dealer_id] = [];
    dealerGroups[o.dealer_id].push(o);
  });

  const totalPlaced    = orders.filter(o => o.order_status === 'ORDER_PLACED').length;
  const totalAccepted  = orders.filter(o => o.order_status === 'ACCEPTED').length;
  const totalDealers   = Object.keys(dealerGroups).length;

  return (
    <div>
      {toast && <Toast msg={toast.msg} type={toast.type} onClose={() => setToast(null)} />}

      {dispatchModal && (
        <DispatchModal
          order={dispatchModal}
          loadingLocations={loadingLocs}
          onSubmit={handleDispatch}
          onClose={() => setDispatchModal(null)}
        />
      )}

      {/* Stats */}
      <div className="row g-3 mb-4">
        <div className="col-6 col-md-4">
          <div className="card border-0 shadow-sm" style={{ borderLeft: '4px solid #fd7e14' }}>
            <div className="card-body d-flex align-items-center gap-3 py-3">
              <span style={{ fontSize: '1.8rem' }}>🕐</span>
              <div>
                <div className="fs-4 fw-bold">{totalPlaced}</div>
                <div className="text-muted small">Orders Placed</div>
              </div>
            </div>
          </div>
        </div>
        <div className="col-6 col-md-4">
          <div className="card border-0 shadow-sm" style={{ borderLeft: '4px solid #0dcaf0' }}>
            <div className="card-body d-flex align-items-center gap-3 py-3">
              <span style={{ fontSize: '1.8rem' }}>✅</span>
              <div>
                <div className="fs-4 fw-bold">{totalAccepted}</div>
                <div className="text-muted small">Accepted</div>
              </div>
            </div>
          </div>
        </div>
        <div className="col-6 col-md-4">
          <div className="card border-0 shadow-sm" style={{ borderLeft: '4px solid #6f42c1' }}>
            <div className="card-body d-flex align-items-center gap-3 py-3">
              <span style={{ fontSize: '1.8rem' }}>🏬</span>
              <div>
                <div className="fs-4 fw-bold">{totalDealers}</div>
                <div className="text-muted small">Active Dealers</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      {/* Filters */}
      <div className="d-flex align-items-center gap-3 mb-4 flex-wrap p-3 bg-white rounded shadow-sm">
        <span className="fw-semibold text-muted small text-uppercase">Filters:</span>
        <div className="form-check form-switch mb-0">
          <input className="form-check-input" type="checkbox" id="toggleOnHold"
            checked={showOnHold} onChange={e => setShowOnHold(e.target.checked)} />
          <label className="form-check-label" htmlFor="toggleOnHold">⏸️ Show On Hold</label>
        </div>
        <div className="form-check form-switch mb-0">
          <input className="form-check-input" type="checkbox" id="toggleDispatched"
            checked={showDispatched} onChange={e => setShowDispatched(e.target.checked)} />
          <label className="form-check-label" htmlFor="toggleDispatched">🚛 Show Dispatched</label>
        </div>
        <button className="btn btn-sm btn-outline-secondary ms-auto" onClick={fetchOrders} disabled={loading}>
          {loading
            ? <span className="spinner-border spinner-border-sm"></span>
            : '🔄'} Refresh
        </button>
      </div>

      {/* Content */}
      {loading ? (
        <div className="text-center py-5 text-muted">
          <div className="spinner-border mb-3" role="status"></div>
          <div>Loading orders…</div>
        </div>
      ) : Object.keys(dealerGroups).length === 0 ? (
        <div className="text-center py-5">
          <div style={{ fontSize: '3rem' }}>📭</div>
          <h5 className="text-muted mt-3">No active orders</h5>
          <p className="text-muted small">All orders are dispatched or there are no pending orders.</p>
        </div>
      ) : (
        Object.entries(dealerGroups).map(([dealerId, dealerOrders]) => (
          <DealerGroup
            key={dealerId}
            orders={dealerOrders}
            onAccept={handleAccept}
            onDispatch={order => setDispatchModal(order)}
          />
        ))
      )}
    </div>
  );
}

ReactDOM.createRoot(document.getElementById('app-root')).render(<App />);
</script>

<%- include('../partials/footer') %>
