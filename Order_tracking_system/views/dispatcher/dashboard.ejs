<%- include('../partials/header') %>
<script src="https://cdn.jsdelivr.net/npm/react@18/umd/react.development.js"></script>
<script src="https://cdn.jsdelivr.net/npm/react-dom@18/umd/react-dom.development.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@babel/standalone/babel.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/browser-image-compression@2.0.0/dist/browser-image-compression.js"></script>

<nav aria-label="breadcrumb" class="mb-3">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
    <li class="breadcrumb-item active">Dispatch Dashboard</li>
  </ol>
</nav>

<div id="app-root"></div>

<style>
  .count-card {
    cursor: pointer !important;
    transition: all 0.2s ease !important;
  }
  .count-card:hover {
    transform: translateY(-4px) !important;
    box-shadow: 0 8px 16px rgba(0,0,0,0.15) !important;
  }
  .count-card.disabled {
    cursor: default !important;
  }
  .count-card.disabled:hover {
    transform: none !important;
    box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075) !important;
  }
</style>

<script type="text/babel">
const { useState, useEffect, useCallback, useRef } = React;

const STATUS_CONFIG = {
  ORDER_PLACED: { text: 'Order Placed', icon: '🕐', bg: '#fd7e14', tc: '#fff' },
  ACCEPTED:     { text: 'Accepted',     icon: '✅', bg: '#0dcaf0', tc: '#000' },
  DISPATCHED:   { text: 'Dispatched',   icon: '🚛', bg: '#198754', tc: '#fff' },
  ON_HOLD:      { text: 'On Hold',      icon: '⏸️', bg: '#e57373', tc: '#fff' },
};

function fmt(value) {
  if (!value) return '—';
  const dt = new Date(value);
  if (isNaN(dt.getTime())) return value;
  return new Intl.DateTimeFormat('en-IN', {
    day: '2-digit', month: 'short', year: 'numeric',
    hour: '2-digit', minute: '2-digit', hour12: true,
  }).format(dt);
}

function StatusBadge({ status }) {
  const cfg = STATUS_CONFIG[status] || { bg: '#6c757d', tc: '#fff', text: status, icon: '' };
  return (
    <span className="badge" style={{ background: cfg.bg, color: cfg.tc }}>
      {cfg.icon} {cfg.text}
    </span>
  );
}

function Toast({ msg, type, onClose }) {
  useEffect(() => {
    const t = setTimeout(onClose, 4000);
    return () => clearTimeout(t);
  }, []);
  return (
    <div style={{
      position: 'fixed', top: 80, right: 20, zIndex: 9999, minWidth: 280,
      background: type === 'success' ? '#198754' : '#dc3545',
      color: '#fff', padding: '12px 18px', borderRadius: 8,
      boxShadow: '0 4px 16px rgba(0,0,0,.25)'
    }}>
      {type === 'success' ? '✅' : '❌'} {msg}
    </div>
  );
}

function DispatchModal({ order, loadingLocations, onSubmit, onClose }) {
  const [form, setForm] = useState({
    vehicle_number: order.load_type_code === 'SLF_DOT' ? (order.vehicle_number_on_order || '') : '',
    driver_name: order.load_type_code === 'SLF_DOT' ? (order.driver_name_on_order || '') : '',
    driver_phone: order.load_type_code === 'SLF_DOT' ? (order.driver_phone_on_order || '') : '',
    bilty_number: '',
    actual_loading_location_code: '',
  });
  const [saving, setSaving] = useState(false);
  const [err, setErr] = useState('');

  // Receipt upload states
  const [selectedFile, setSelectedFile] = useState(null);
  const [imagePreview, setImagePreview] = useState(null);
  const [uploading, setUploading] = useState(false);
  const [uploadProgress, setUploadProgress] = useState(0);
  const [uploadedImageUrl, setUploadedImageUrl] = useState(null);
  const [imageMetadata, setImageMetadata] = useState(null);
  const [skipUploadConfirm, setSkipUploadConfirm] = useState(false);

  const set = (k, v) => setForm(f => ({ ...f, [k]: v }));

  const handleFileSelect = async (e) => {
    const file = e.target.files?.[0];
    if (!file) return;

    // Validate file type
    const validTypes = ['image/jpeg', 'image/png', 'image/jpg', 'image/gif', 'image/webp'];
    if (!validTypes.includes(file.type)) {
      setErr('Please select a valid image file (JPG, PNG, GIF, WebP)');
      return;
    }

    setSelectedFile(file);
    const reader = new FileReader();
    reader.onload = (evt) => setImagePreview(evt.target.result);
    reader.readAsDataURL(file);
    setErr('');
    setSkipUploadConfirm(false);
  };

  const uploadReceipt = async () => {
    if (!selectedFile) return;

    try {
      setUploading(true);
      setErr('');

      let fileToUpload = selectedFile;
      let compressedSize = null;

      // Compress if file > 500KB
      if (selectedFile.size > 500 * 1024 && typeof window.ImageCompression !== 'undefined') {
        setUploadProgress(10);
        try {
          const options = {
            maxSizeMB: 0.5,
            maxWidthOrHeight: 1920,
            useWebWorker: true,
          };
          fileToUpload = await window.ImageCompression.compress(selectedFile, options);
          compressedSize = fileToUpload.size;
          console.log(`Compressed image: ${selectedFile.size} → ${fileToUpload.size} bytes`);
        } catch (compressError) {
          console.warn('Image compression failed, using original:', compressError.message);
        }
      }

      setUploadProgress(20);

      // Step 1: Request presigned URL from backend
      console.log('Requesting presigned URL from backend...');
      const presignedRes = await fetch('/api/dispatcher/presigned-url', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          order_id: order.order_id,
          dealer_id: order.dealer_id,
          file_name: fileToUpload.name,
          file_type: fileToUpload.type,
        }),
      });

      if (!presignedRes.ok) {
        const errorData = await presignedRes.json().catch(() => ({}));
        throw new Error(errorData.error || `Failed to get presigned URL: ${presignedRes.status}`);
      }

      const { url: presignedUrl, s3Key } = await presignedRes.json();
      console.log('Presigned URL received:', s3Key);
      setUploadProgress(40);

      // Step 2: Upload file directly to S3 using presigned URL
      console.log('Uploading file directly to S3...');
      const s3UploadRes = await fetch(presignedUrl, {
        method: 'PUT',
        body: fileToUpload,
        headers: { 'Content-Type': fileToUpload.type },
      });

      if (!s3UploadRes.ok) {
        throw new Error(`S3 upload failed: ${s3UploadRes.status} ${s3UploadRes.statusText}`);
      }

      setUploadProgress(80);

      // Step 3: Construct S3 URL from s3Key
      // Extract bucket and region from presignedUrl
      const s3Url = presignedUrl.split('?')[0]; // Remove query params from presigned URL
      console.log('Receipt uploaded to S3:', s3Url);

      setUploadProgress(95);

      // Store metadata
      setUploadedImageUrl(s3Url);
      setImageMetadata({
        image_url: s3Url,
        image_type: fileToUpload.type,
        image_original_size: selectedFile.size,
        image_compressed_size: compressedSize,
      });

      setUploadProgress(100);
      setUploading(false);
    } catch (error) {
      console.error('Upload error:', error);
      setErr(`Upload failed: ${error.message}`);
      setUploading(false);
      setUploadProgress(0);
    }
  };

  const submit = async () => {
    if (!form.vehicle_number.trim())                return setErr('Vehicle number is required');
    if (!form.driver_phone.trim())                  return setErr('Driver phone is required');
    if (!/^\d{10}$/.test(form.driver_phone.trim())) return setErr('Driver phone must be exactly 10 digits');
    if (!form.bilty_number.trim())                  return setErr('Bilty number is required');
    if (!form.actual_loading_location_code)         return setErr('Actual loading location is required');

    // Check if image is selected but not uploaded
    if (selectedFile && !uploadedImageUrl && !skipUploadConfirm) {
      setSkipUploadConfirm(true);
      return;
    }

    setErr('');
    setSaving(true);
    const finalForm = { ...form, ...imageMetadata };
    await onSubmit(order.order_id, finalForm);
    setSaving(false);
  };

  return (
    <div className="modal d-block" tabIndex="-1" style={{ background: 'rgba(0,0,0,0.55)' }}>
      <div className="modal-dialog modal-dialog-centered modal-lg">
        <div className="modal-content">

          <div className="modal-header" style={{ background: '#198754', color: '#fff' }}>
            <h5 className="modal-title">🚛 Dispatch — Order #{order.order_id}</h5>
            <button type="button" className="btn-close btn-close-white" onClick={onClose}></button>
          </div>

          <div className="modal-body">
            {/* Order summary */}
            <div className="row g-2 mb-4 p-3 rounded" style={{ background: '#f8faff' }}>
              <div className="col-6 col-md-4">
                <div className="text-muted small">Dealer</div>
                <div className="fw-semibold">{order.dealer_login_name || order.dealer_company_name || order.dealer_name}</div>
              </div>
              <div className="col-6 col-md-4">
                <div className="text-muted small">Order Time</div>
                <div className="fw-semibold" style={{ fontSize: '.85rem' }}>{fmt(order.order_date)}</div>
              </div>
              {/* Products & Quantities */}
              {(() => {
                const items = parseItems(order);
                const total = items.reduce((s, i) => s + parseFloat(i.order_quantity || 0), 0);
                if (items.length > 1) {
                  return (
                    <div className="col-12">
                      <div className="text-muted small mb-1 fw-semibold">Products &amp; Quantities</div>
                      <table className="table table-sm table-bordered mb-0" style={{ fontSize: '.85rem', background: '#fff' }}>
                        <thead className="table-light">
                          <tr><th>Product</th><th style={{ width: 80 }}>Bags</th><th style={{ width: 100 }}>Qty (MT)</th></tr>
                        </thead>
                        <tbody>
                          {items.map((item, idx) => (
                            <tr key={idx}>
                              <td>{item.product_name || `#${item.product_id}`}</td>
                              <td>{item.order_bags || '—'}</td>
                              <td>{parseFloat(item.order_quantity).toFixed(3)}</td>
                            </tr>
                          ))}
                        </tbody>
                        <tfoot>
                          <tr className="table-secondary fw-bold">
                            <td colSpan={2} className="text-muted small">Total</td>
                            <td>{total.toFixed(3)}</td>
                          </tr>
                        </tfoot>
                      </table>
                    </div>
                  );
                }
                const single = items[0];
                return (
                  <>
                    <div className="col-6 col-md-4">
                      <div className="text-muted small">Product</div>
                      <div className="fw-semibold">{single ? (single.product_name || `#${single.product_id}`) : '—'}</div>
                    </div>
                    <div className="col-6 col-md-4">
                      <div className="text-muted small">Quantity</div>
                      <div className="fw-semibold">{single ? parseFloat(single.order_quantity).toFixed(3) : (order.order_quantity || '—')} MT</div>
                    </div>
                    {single && single.order_bags && (
                      <div className="col-6 col-md-4">
                        <div className="text-muted small">No. of Bags</div>
                        <div className="fw-semibold">{single.order_bags}</div>
                      </div>
                    )}
                  </>
                );
              })()}
              <div className="col-6 col-md-4">
                <div className="text-muted small">Party</div>
                <div className="fw-semibold">{order.party_company_name || order.party_name_col || '—'}</div>
              </div>
              <div className="col-6 col-md-4">
                <div className="text-muted small">Delivery Address</div>
                <div className="fw-semibold">{order.party_address || '—'}</div>
              </div>
              <div className="col-6 col-md-4">
                <div className="text-muted small">Party Phone</div>
                <div className="fw-semibold">
                  {order.party_phone
                    ? <a href={`tel:${order.party_phone}`}>{order.party_phone}</a>
                    : '—'}
                </div>
              </div>
              <div className="col-6 col-md-6">
                <div className="text-muted small">Load Type</div>
                <div className="fw-semibold">{order.load_type_desc || order.load_type_code || '—'}</div>
              </div>
              <div className="col-6 col-md-6">
                <div className="text-muted small">Preferred Loading Location</div>
                <div className="fw-semibold">{order.preferred_location_desc || order.preferred_location_code || '—'}</div>
              </div>
            </div>

            {/* Receipt upload section */}
            <div className="mb-4 p-3 border rounded" style={{ background: '#fffbf0', borderColor: '#ffe0b2' }}>
              <h6 className="fw-bold text-muted text-uppercase small mb-3">📸 Receipt Photo (Optional)</h6>

              {!uploadedImageUrl ? (
                <>
                  <div className="mb-3">
                    <input
                      type="file"
                      accept="image/*"
                      onChange={handleFileSelect}
                      disabled={uploading}
                      className="form-control"
                    />
                    <small className="text-muted d-block mt-1">Accepted: JPG, PNG, GIF, WebP. Auto-compressed to ~500 KB if larger.</small>
                  </div>

                  {imagePreview && (
                    <div className="mb-3">
                      <div className="mb-2">
                        <img src={imagePreview} alt="Preview" style={{ maxWidth: '100%', maxHeight: 150, borderRadius: 4 }} />
                      </div>
                      {!uploading && (
                        <button
                          type="button"
                          className="btn btn-sm btn-primary"
                          onClick={uploadReceipt}
                          disabled={uploading}
                        >
                          📤 Upload Receipt
                        </button>
                      )}
                    </div>
                  )}

                  {uploading && (
                    <div className="mb-3">
                      <div className="progress" style={{ height: 24 }}>
                        <div
                          className="progress-bar progress-bar-striped progress-bar-animated"
                          style={{ width: `${uploadProgress}%` }}
                        >
                          {uploadProgress}%
                        </div>
                      </div>
                    </div>
                  )}
                </>
              ) : (
                <div className="alert alert-success py-2 mb-0">
                  ✅ Receipt uploaded successfully
                </div>
              )}

              {skipUploadConfirm && !uploadedImageUrl && (
                <div className="alert alert-warning py-2 mt-2 mb-0">
                  <strong>⚠️ No receipt uploaded</strong>
                  <p className="mb-2 mt-2">You have not uploaded a receipt for this order. Do you want to continue without it?</p>
                  <div className="btn-group btn-group-sm" role="group">
                    <button
                      type="button"
                      className="btn btn-warning"
                      onClick={() => setSkipUploadConfirm(false)}
                    >
                      No, Upload Receipt
                    </button>
                    <button
                      type="button"
                      className="btn btn-outline-warning"
                      onClick={() => {
                        setSkipUploadConfirm(false);
                        setSaving(true);
                        onSubmit(order.order_id, { ...form, ...imageMetadata });
                      }}
                    >
                      Yes, Continue Without Receipt
                    </button>
                  </div>
                </div>
              )}
            </div>

            {/* Dispatch form */}
            <h6 className="fw-bold text-muted text-uppercase small mb-3">Enter Dispatch Details</h6>
            {err && !skipUploadConfirm && <div className="alert alert-danger py-2 mb-3">{err}</div>}

            <div className="row g-3">
              <div className="col-md-6">
                <label className="form-label fw-semibold">
                  Vehicle Number <span className="text-danger">*</span>
                </label>
                <input
                  className="form-control text-uppercase"
                  placeholder="e.g. UP32AB1234"
                  value={form.vehicle_number}
                  onChange={e => set('vehicle_number', e.target.value.toUpperCase())}
                />
              </div>
              <div className="col-md-6">
                <label className="form-label fw-semibold">
                  Bilty Number <span className="text-danger">*</span>
                </label>
                <input
                  className="form-control"
                  placeholder="Transport receipt / bilty number"
                  value={form.bilty_number}
                  onChange={e => set('bilty_number', e.target.value)}
                />
              </div>
              <div className="col-md-6">
                <label className="form-label fw-semibold">Driver Name</label>
                <input
                  className="form-control"
                  placeholder="Driver full name (optional)"
                  value={form.driver_name}
                  onChange={e => set('driver_name', e.target.value)}
                />
              </div>
              <div className="col-md-6">
                <label className="form-label fw-semibold">
                  Driver Phone <span className="text-danger">*</span>
                </label>
                <input
                  className="form-control"
                  placeholder="10-digit mobile number"
                  maxLength={10}
                  value={form.driver_phone}
                  onChange={e => set('driver_phone', e.target.value.replace(/\D/g, ''))}
                />
              </div>
              <div className="col-12">
                <label className="form-label fw-semibold">
                  Actual Loading Location <span className="text-danger">*</span>
                </label>
                <select
                  className="form-select"
                  value={form.actual_loading_location_code}
                  onChange={e => set('actual_loading_location_code', e.target.value)}
                >
                  <option value="">-- Select Actual Loading Location --</option>
                  {loadingLocations.map(l => (
                    <option key={l.code} value={l.code}>
                      {l.code_desc || l.code}
                    </option>
                  ))}
                </select>
              </div>
            </div>
          </div>

          <div className="modal-footer">
            <button className="btn btn-secondary" onClick={onClose}>Cancel</button>
            <button className="btn btn-success" disabled={saving} onClick={submit}>
              {saving && <span className="spinner-border spinner-border-sm me-1"></span>}
              🚛 Confirm Dispatch
            </button>
          </div>

        </div>
      </div>
    </div>
  );
}

function parseItems(order) {
  const raw = order.items;
  if (!raw) return [];
  const arr = typeof raw === 'string' ? JSON.parse(raw) : raw;
  return Array.isArray(arr) ? arr.filter(i => i && i.product_id) : [];
}

function ItemsCell({ order }) {
  const items = parseItems(order);
  if (items.length === 0) return <span className="text-muted">—</span>;
  if (items.length === 1) return <span>{items[0].product_name || `#${items[0].product_id}`}</span>;
  return (
    <span>
      {items[0].product_name || `#${items[0].product_id}`}
      <span className="badge bg-secondary ms-1" style={{ fontSize: '.7rem' }}>+{items.length - 1}</span>
    </span>
  );
}

function QtyCell({ order }) {
  const items = parseItems(order);
  const total = items.reduce((s, i) => s + parseFloat(i.order_quantity || 0), 0);
  const display = total > 0 ? total : parseFloat(order.order_quantity || 0);
  return <span>{display % 1 === 0 ? display : display.toFixed(3)} MT</span>;
}

function ViewOrderModal({ order, onClose, onBack }) {
  if (!order) return null;
  return (
    <div className="modal d-block" tabIndex="-1" style={{ background: 'rgba(0,0,0,0.5)' }}>
      <div className="modal-dialog modal-dialog-centered modal-lg">
        <div className="modal-content">
          <div className="modal-header bg-info text-white d-flex align-items-center justify-content-between">
            <div className="d-flex align-items-center gap-2">
              {onBack && (
                <button type="button" className="btn btn-sm btn-light" onClick={onBack} title="Go back">
                  ← Back
                </button>
              )}
              <h5 className="modal-title mb-0">📋 Order #{order.order_id} — Details</h5>
            </div>
            <button type="button" className="btn-close btn-close-white" onClick={onClose}></button>
          </div>
          <div className="modal-body" style={{ maxHeight: '70vh', overflowY: 'auto' }}>
            {/* Order Info */}
            <h6 className="fw-bold text-muted mb-3 text-uppercase small">Order Information</h6>
            <div className="row g-3 mb-4">
              <div className="col-md-4">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Dealer</div>
                  <div className="fw-semibold">{order.dealer_name || '—'}</div>
                </div>
              </div>
              <div className="col-md-4">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Order Date</div>
                  <div className="fw-semibold">{fmt(order.order_date)}</div>
                </div>
              </div>
              <div className="col-md-4">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Status</div>
                  <div><StatusBadge status={order.order_status} /></div>
                </div>
              </div>
              <div className="col-12">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small mb-2 fw-semibold">Products & Quantities</div>
                  <table className="table table-sm table-bordered mb-0" style={{ fontSize: '.88rem' }}>
                    <thead className="table-light">
                      <tr>
                        <th>Product</th>
                        <th style={{ width: 90 }}>Bags</th>
                        <th style={{ width: 110 }}>Qty (MT)</th>
                      </tr>
                    </thead>
                    <tbody>
                      {order.items && order.items.length > 0 ? (
                        order.items.map((item, idx) => (
                          <tr key={idx}>
                            <td>{item.product_name || `#${item.product_id}`}</td>
                            <td>{item.order_bags || '—'}</td>
                            <td>{parseFloat(item.order_quantity).toFixed(3)}</td>
                          </tr>
                        ))
                      ) : (
                        <tr><td colSpan={3} className="text-muted text-center py-2">No items</td></tr>
                      )}
                    </tbody>
                  </table>
                </div>
              </div>
              <div className="col-md-6">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Party</div>
                  <div className="fw-semibold">{order.party_company_name || order.party_name_col || '—'}</div>
                </div>
              </div>
              <div className="col-md-6">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Party Phone</div>
                  <div className="fw-semibold">
                    {order.party_phone
                      ? <a href={`tel:${order.party_phone}`}>{order.party_phone}</a>
                      : '—'}
                  </div>
                </div>
              </div>
              <div className="col-12">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Delivery Address</div>
                  <div className="fw-semibold">{order.party_address || '—'}</div>
                </div>
              </div>
              <div className="col-md-6">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Load Type</div>
                  <div className="fw-semibold">{order.load_type_desc || order.load_type_code || '—'}</div>
                </div>
              </div>
              <div className="col-md-6">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Preferred Loading Location</div>
                  <div className="fw-semibold">{order.preferred_location_desc || order.preferred_location_code || '—'}</div>
                </div>
              </div>

              {/* Self DOT Driver Details (if applicable) */}
              {order.load_type_code === 'SLF_DOT' && (order.driver_name_on_order || order.driver_phone_on_order || order.vehicle_number_on_order) && (
                <div className="col-12">
                  <div className="p-3 border rounded" style={{ background: '#f0f8ff', borderColor: '#b0d4f1' }}>
                    <div className="fw-semibold small text-primary mb-3">🚛 Self DOT — Driver Details</div>
                    <div className="row g-3">
                      <div className="col-md-4">
                        <div className="text-muted small">Driver Name</div>
                        <div className="fw-semibold">{order.driver_name_on_order || '—'}</div>
                      </div>
                      <div className="col-md-4">
                        <div className="text-muted small">Driver Phone</div>
                        <div className="fw-semibold">{order.driver_phone_on_order || '—'}</div>
                      </div>
                      <div className="col-md-4">
                        <div className="text-muted small">Vehicle Number</div>
                        <div className="fw-semibold">{order.vehicle_number_on_order || '—'}</div>
                      </div>
