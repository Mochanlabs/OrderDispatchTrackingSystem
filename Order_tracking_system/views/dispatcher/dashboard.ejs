function OrderRow({ order, onAccept, onDispatch, onView, isOrderOverdue }) {
  const [accepting, setAccepting] = useState(false);

  const handleAccept = async () => {
    setAccepting(true);
    await onAccept(order.order_id);
    setAccepting(false);
  };

  return (
    <tr style={{ backgroundColor: isOrderOverdue(order) ? '#fff3cd' : 'transparent' }}>
      <td className="fw-semibold text-nowrap">
        #{order.order_id}
        {isOrderOverdue(order) && (
          <span title="Order is 3+ days old and not dispatched" style={{ color: '#dc3545', marginLeft: '0.5rem' }}>
            ⚠️
          </span>
        )}
      </td>
      <td className="text-nowrap" style={{ fontSize: '.8rem' }}>{fmt(order.order_date)}</td>
      <td><ItemsCell order={order} /></td>
      <td className="text-nowrap"><QtyCell order={order} /></td>
      <td>{order.party_company_name || order.party_name_col || '—'}</td>
      <td className="d-none d-lg-table-cell" style={{ maxWidth: 160, overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }}>
        {order.party_address || '—'}
      </td>
      <td className="d-none d-md-table-cell text-nowrap">
        {order.party_phone
          ? <a href={`tel:${order.party_phone}`}>{order.party_phone}</a>
          : '—'}
      </td>
      <td className="d-none d-xl-table-cell">{order.load_type_desc || order.load_type_code || '—'}</td>
      <td className="d-none d-xl-table-cell">{order.preferred_location_desc || order.preferred_location_code || '—'}</td>
      <td className="d-none d-lg-table-cell text-nowrap">
        {order.actual_location_desc || order.actual_loading_location_code ? (
          <span className="badge bg-success">{order.actual_location_desc || order.actual_loading_location_code}</span>
        ) : (
          <span className="text-muted small">—</span>
        )}
      </td>
      <td><StatusBadge status={order.order_status} /></td>
      <td className="text-nowrap">
        <button className="btn btn-sm btn-outline-primary me-1" onClick={() => onView(order)}>
          👁️ View
        </button>
        {order.order_status === 'ORDER_PLACED' && (
          <button className="btn btn-sm btn-outline-info" disabled={accepting} onClick={handleAccept}>
            {accepting
              ? <span className="spinner-border spinner-border-sm"></span>
              : '✅ Accept'}
          </button>
        )}
        {order.order_status === 'ACCEPTED' && (
          <button className="btn btn-sm btn-success" onClick={() => onDispatch(order)}>
            🚛 Dispatch
          </button>
        )}
        {order.order_status === 'DISPATCHED' && (
          <div style={{ fontSize: '.8rem' }}>
            {order.dispatch_vehicle_number && <div className="text-muted">🚗 {order.dispatch_vehicle_number}</div>}
            {order.driver_phone && (
              <a href={`tel:${order.driver_phone}`} className="d-block">📞 {order.driver_phone}</a>
            )}
          </div>
        )}
        {order.order_status === 'ON_HOLD' && (
          <span className="text-muted small">—</span>
        )}
      </td>
    </tr>
  );
}

