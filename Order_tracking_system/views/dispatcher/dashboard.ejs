function DealerOrdersModal({ orders, dealerId, onClose, onBack, onAccept, onDispatch, onView }) {
  const [accepting, setAccepting] = useState({});

  const dealerOrders = orders
    .filter(o => o.dealer_id === dealerId && (o.order_status === 'ORDER_PLACED' || o.order_status === 'ACCEPTED'))
    .sort((a, b) => new Date(a.order_date) - new Date(b.order_date));

  const dealerName = dealerOrders[0]?.dealer_login_name || dealerOrders[0]?.dealer_company_name || dealerOrders[0]?.dealer_name || `Dealer #${dealerId}`;

  const handleAccept = async (orderId) => {
    setAccepting(prev => ({ ...prev, [orderId]: true }));
    await onAccept(orderId);
    setAccepting(prev => ({ ...prev, [orderId]: false }));
  };

  return (
    <div className="modal d-block" tabIndex="-1" style={{ background: 'rgba(0,0,0,0.55)' }}>
      <div className="modal-dialog modal-dialog-centered modal-lg">
        <div className="modal-content">
