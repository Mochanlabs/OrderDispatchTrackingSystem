                        <div className="fw-semibold">{dealer.dealer_login_name || dealer.dealer_company_name || dealer.dealer_name}</div>
                        {dealer.dealer_company_name && dealer.dealer_login_name && dealer.dealer_company_name !== dealer.dealer_login_name && (
                          <small className="text-muted">{dealer.dealer_company_name}</small>
                        )}
                      </div>
                      <span className="badge bg-info">{dealer.total}</span>
                    </div>
                  </button>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  );
}

