<%- include('../partials/header') %>
<script src="https://cdn.jsdelivr.net/npm/react@18/umd/react.development.js"></script>
<script src="https://cdn.jsdelivr.net/npm/react-dom@18/umd/react-dom.development.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@babel/standalone/babel.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
<script>window._IS_ADMIN = <%- isAdmin ? 'true' : 'false' %>;</script>

<nav aria-label="breadcrumb" class="mb-3">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
    <li class="breadcrumb-item active"><%= isAdmin ? 'All Orders & Dispatch' : 'My Orders' %></li>
  </ol>
</nav>
<div id="app-root"></div>

<script type="text/babel">
const { useState, useEffect } = React;
const IS_ADMIN = window._IS_ADMIN === true;

const STATUS_CONFIG = {
  ORDER_PLACED: { text: 'Order Placed', icon: '🕐', bg: '#fd7e14', tc: '#fff' },
  ACCEPTED:     { text: 'Accepted',     icon: '✅', bg: '#0dcaf0', tc: '#000' },
  DISPATCHED:   { text: 'Dispatched',   icon: '📦', bg: '#198754', tc: '#fff' },
  ON_HOLD:      { text: 'On Hold',      icon: '⏸️', bg: '#e57373', tc: '#fff' },
};

const UNITS = ['MT', 'KG', 'NOS', 'PCS', 'TON'];

const EMPTY_FORM = { product_name: '', quantity: '', unit: 'MT', delivery_location: '', remarks: '' };

function formatDateTime(value) {
  if (!value) return '—';
  const dt = new Date(value);
  if (Number.isNaN(dt.getTime())) return value;
  return new Intl.DateTimeFormat('en-IN', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
    second: '2-digit',
    hour12: true,
  }).format(dt);
}

function StatusBadge({ status }) {
  const cfg = STATUS_CONFIG[status] || { bg: '#6c757d', tc: '#fff', text: status };
  return (
    <span className="badge" style={{ background: cfg.bg, color: cfg.tc }}>
      {cfg.icon} {cfg.text}
    </span>
  );
}

function OnHoldModal({ order, onConfirm, onClose, requireReason }) {
  const [reason, setReason] = React.useState('');
  const [saving, setSaving] = React.useState(false);
  const [error, setError] = React.useState('');

  const handleConfirm = async () => {
    if (requireReason && !reason.trim()) {
      setError('Hold reason is required');
      return;
    }
    setSaving(true);
    await onConfirm(reason.trim());
    setSaving(false);
  };

  return (
    <div className="modal d-block" tabIndex="-1" style={{ background: 'rgba(0,0,0,0.5)' }}>
      <div className="modal-dialog modal-dialog-centered">
        <div className="modal-content">
          <div className="modal-header bg-warning">
            <h5 className="modal-title">⏸️ Put Order #{order.order_id} On Hold</h5>
            <button type="button" className="btn-close" onClick={onClose}></button>
          </div>
          <div className="modal-body">
            <p className="text-muted mb-3 small">This order will be paused. {requireReason ? 'You must provide a reason.' : 'Only you can reopen it.'} Orders that are <strong>Accepted</strong> or <strong>Dispatched</strong> cannot be put on hold.</p>
            {error && <div className="alert alert-danger py-2 px-3 mb-3">{error}</div>}
            <div className="mb-1">
              <label className="form-label fw-semibold">
                Reason {requireReason && <span className="text-danger">*</span>}
                {!requireReason && <span className="text-muted fw-normal small">(optional)</span>}
              </label>
              <textarea
                className="form-control"
                rows="3"
                placeholder="e.g. Awaiting yard space, pending payment, Party request…"
                value={reason}
                onChange={e => { setReason(e.target.value); setError(''); }}
              />
            </div>
          </div>
          <div className="modal-footer">
            <button type="button" className="btn btn-secondary" onClick={onClose}>Cancel</button>
            <button type="button" className="btn btn-warning" disabled={saving || (requireReason && !reason.trim())}
              onClick={handleConfirm}>
              {saving && <span className="spinner-border spinner-border-sm me-1"></span>}
              Confirm Hold
            </button>
          </div>
        </div>
      </div>
    </div>
  );
}

function SummaryCard({ label, value, icon, borderColor }) {
  return (
    <div className="col-6 col-md-3 mb-3">
      <div className="card border-0 shadow-sm h-100" style={{ borderLeft: `4px solid ${borderColor}` }}>
        <div className="card-body d-flex align-items-center gap-3 py-3">
          <div style={{ fontSize: '2rem' }}>{icon}</div>
          <div>
            <div className="fs-4 fw-bold">{value}</div>
            <div className="text-muted small">{label}</div>
          </div>
        </div>
      </div>
    </div>
  );
}

function DispatchModal({ order, onClose }) {
  if (!order) return null;
  const d = order.dispatch;
  return (
    <div className="modal d-block" tabIndex="-1" style={{ background: 'rgba(0,0,0,0.5)' }}>
      <div className="modal-dialog modal-dialog-centered modal-lg">
        <div className="modal-content">
          <div className="modal-header bg-primary text-white">
            <h5 className="modal-title">📋 Order #{order.order_id} — Dispatch Details</h5>
            <button type="button" className="btn-close btn-close-white" onClick={onClose}></button>
          </div>
          <div className="modal-body">
            {/* Order Info */}
            <h6 className="fw-bold text-muted mb-3 text-uppercase small">Order Information</h6>
            <div className="row g-3 mb-4">
              {/* Row 1: Products & Quantities */}
              {order.items && order.items.length > 0 ? (
                <div className="col-12">
                  <div className="p-3 bg-light rounded">
                    <div className="text-muted small mb-2 fw-semibold">Products &amp; Quantities</div>
                    <table className="table table-sm table-bordered mb-0" style={{ fontSize: '.88rem' }}>
                      <thead className="table-light">
                        <tr>
                          <th>Product</th>
                          <th style={{ width: 90 }}>Bags</th>
                          <th style={{ width: 110 }}>Qty (MT)</th>
                        </tr>
                      </thead>
                      <tbody>
                        {order.items.map((item, idx) => (
                          <tr key={idx}>
                            <td>{item.product_name || `Product #${item.product_id}`}</td>
                            <td>{item.order_bags || '—'}</td>
                            <td>{parseFloat(item.order_quantity).toFixed(3)}</td>
                          </tr>
                        ))}
                      </tbody>
                      {order.items.length > 1 && (
                        <tfoot>
                          <tr className="table-secondary fw-bold">
                            <td colSpan={2} className="text-muted small">Total</td>
                            <td>{order.quantity.toFixed(3)}</td>
                          </tr>
                        </tfoot>
                      )}
                    </table>
                  </div>
                </div>
              ) : (
                <>
                  <div className="col-md-6">
                    <div className="p-3 bg-light rounded">
                      <div className="text-muted small">Product</div>
                      <div className="fw-semibold">{order.product_name || '—'}</div>
                    </div>
                  </div>
                  <div className="col-md-6">
                    <div className="p-3 bg-light rounded">
                      <div className="text-muted small">Quantity</div>
                      <div className="fw-semibold">{order.quantity} {order.unit}</div>
                    </div>
                  </div>
                </>
              )}
              {/* Row 2: Party Company Name + Party Phone + Party Address */}
              <div className="col-md-4">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Party Company Name</div>
                  <div className="fw-semibold">{order.party_name || '—'}</div>
                </div>
              </div>
              <div className="col-md-4">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Party Phone</div>
                  <div className="fw-semibold">{order.party_phone || '—'}</div>
                </div>
              </div>
              <div className="col-md-4">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Party Address</div>
                  <div className="fw-semibold">{order.party_address || '—'}</div>
                </div>
              </div>
              {/* Row 3: Load Type + Preferred Loading Location */}
              <div className="col-md-6">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Load Type</div>
                  <div className="fw-semibold">{order.load_type_desc || '—'}</div>
                </div>
              </div>
              <div className="col-md-6">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Preferred Loading Location</div>
                  <div className="fw-semibold">{order.preferred_location_desc || '—'}</div>
                </div>
              </div>
              {/* Row 4: Order Date + Order Status */}
              <div className="col-md-6">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Order Date</div>
                  <div className="fw-semibold">{formatDateTime(order.order_date)}</div>
                </div>
              </div>
              <div className="col-md-6">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Order Status</div>
                  <div><StatusBadge status={order.order_status}/></div>
                </div>
              </div>
              {order.remarks && (
                <div className="col-12">
                  <div className="p-3 bg-light rounded">
                    <div className="text-muted small">Remarks</div>
                    <div className="fw-semibold">{order.remarks}</div>
                  </div>
                </div>
              )}
              {order.on_hold_reason && (
                <div className="col-12">
                  <div className="p-3 bg-warning bg-opacity-10 rounded border border-warning">
                    <div className="text-muted small">⏸️ On Hold Reason</div>
                    <div className="fw-semibold">{order.on_hold_reason}</div>
                    {order.on_hold_by && <div className="text-muted small mt-1">By: {order.on_hold_by_role || 'Unknown'}</div>}
                  </div>
                </div>
              )}
            </div>

            {/* Dispatch Info */}
            {d ? (
              <>
                <h6 className="fw-bold text-muted mb-3 text-uppercase small">Dispatch Information</h6>
                <div className="row g-3">
                  <div className="col-md-4">
                    <div className="p-3 bg-light rounded">
                      <div className="text-muted small">Dispatch ID</div>
                      <div className="fw-semibold">#{d.dispatch_id}</div>
                    </div>
                  </div>
                  <div className="col-md-4">
                    <div className="p-3 bg-light rounded">
                      <div className="text-muted small">Dispatch Date</div>
                      <div className="fw-semibold">{d.dispatch_date}</div>
                    </div>
                  </div>
                  <div className="col-md-4">
                    <div className="p-3 bg-light rounded">
                      <div className="text-muted small">Vehicle No.</div>
                      <div className="fw-semibold">{d.vehicle_no}</div>
                    </div>
                  </div>
                  <div className="col-md-4">
                    <div className="p-3 bg-light rounded">
                      <div className="text-muted small">Driver Name</div>
                      <div className="fw-semibold">{d.driver_name}</div>
                    </div>
                  </div>
                  <div className="col-md-4">
                    <div className="p-3 bg-light rounded">
                      <div className="text-muted small">Driver Phone</div>
                      <div className="fw-semibold">{d.driver_phone}</div>
                      <div className="d-flex gap-1 mt-2 flex-wrap">
                        <a
                          className="btn btn-sm btn-outline-primary"
                          href={`/tracking?driver=${encodeURIComponent(d.driver_phone)}&order=${order.order_id}`}
                        >
                          📍 Live Track
                        </a>
                        <button type="button" className="btn btn-sm btn-outline-secondary"
                          onClick={()=>{
                            const link = `${window.location.origin}/driver/track?phone=${encodeURIComponent(d.driver_phone)}&order=${order.order_id}&vehicle=${encodeURIComponent(d.vehicle_no||'')}`;
                            navigator.clipboard.writeText(link).then(()=>notify('Driver tracking link copied to clipboard!','success'));
                          }}>
                          🔗 Copy Driver Link
                        </button>
                      </div>
                    </div>
                  </div>
                  <div className="col-md-4">
                    <div className="p-3 bg-light rounded">
                      <div className="text-muted small">Expected Delivery</div>
                      <div className="fw-semibold">{d.expected_delivery}</div>
                    </div>
                  </div>
                  {d.actual_delivery && (
                    <div className="col-md-4">
                      <div className="p-3 bg-success bg-opacity-10 rounded border border-success">
                        <div className="text-muted small">Actual Delivery</div>
                        <div className="fw-semibold text-success">{d.actual_delivery}</div>
                      </div>
                    </div>
                  )}
                </div>

                {/* Progress Tracker */}
                <div className="mt-4">
                  <h6 className="fw-bold text-muted mb-3 text-uppercase small">Order Progress</h6>
                  <div className="d-flex align-items-center gap-0 flex-wrap">
                    {['ORDER_PLACED','ACCEPTED','DISPATCHED'].map((s, i, arr) => {
                      const statuses = ['ORDER_PLACED','ACCEPTED','DISPATCHED'];
                      const currentIdx = statuses.indexOf(order.order_status);
                      const stepIdx = statuses.indexOf(s);
                      const done = stepIdx <= currentIdx;
                      const active = stepIdx === currentIdx;
                      return (
                        <React.Fragment key={s}>
                          <div className="d-flex flex-column align-items-center" style={{flex:'1',minWidth:'60px'}}>
                            <div style={{
                              width:32, height:32, borderRadius:'50%', display:'flex',
                              alignItems:'center', justifyContent:'center', fontSize:14,
                              background: done ? (active ? '#0d6efd' : '#198754') : '#dee2e6',
                              color: done ? '#fff' : '#6c757d', fontWeight:'bold'
                            }}>{done ? (active ? '●' : '✓') : (i+1)}</div>
                            <div className="text-center mt-1" style={{fontSize:'10px', color: done?'#198754':'#6c757d', fontWeight: active?'bold':'normal'}}>
                              {STATUS_CONFIG[s]?.text}
                            </div>
                          </div>
                          {i < arr.length - 1 && (
                            <div style={{flex:'1', height:3, background: stepIdx < currentIdx ? '#198754' : '#dee2e6', minWidth:10, marginBottom:18}}></div>
                          )}
                        </React.Fragment>
                      );
                    })}
                  </div>
                </div>
              </>
            ) : (
              <div className={`alert mt-2 mb-0 ${order.order_status === 'ON_HOLD' ? 'alert-danger' : 'alert-info'}`}>
                {order.order_status === 'ON_HOLD'
                  ? <><strong>Dispatch not yet initiated.</strong> Your order is put on hold. Kindly un-hold your order so it can be further processed.</>
                  : <><strong>Dispatch not yet initiated.</strong> Your order is being processed. Dispatch details will appear here once the order is confirmed and dispatched.</>
                }
              </div>
            )}
          </div>
          <div className="modal-footer">
            <button className="btn btn-secondary" onClick={onClose}>Close</button>
          </div>
        </div>
      </div>
    </div>
  );
}

function CreateForDealerModal({ onClose, onSaved }) {
  const [dealers, setDealers] = useState([]);
  const [products, setProducts] = useState([]);
  const [parties, setParties] = useState([]);
  const [loadTypes, setLoadTypes] = useState([]);
  const [prefLocations, setPrefLocations] = useState([]);
  const [selectedDealerId, setSelectedDealerId] = useState('');
  const [items, setItems] = useState([{ product_id: '', order_bags: '' }]);
  const [partyId, setPartyId] = useState('');
  const [contactNumber, setContactNumber] = useState('');
  const [deliveryAddress, setDeliveryAddress] = useState('');
  const [loadType, setLoadType] = useState('');
  const [prefLocation, setPrefLocation] = useState('');
  const [saving, setSaving] = useState(false);
  const [error, setError] = useState('');

  useEffect(() => {
    Promise.all([
      fetch('/api/dealers').then(r => r.json()),
      fetch('/api/dealer/products').then(r => r.json()),
      fetch('/api/codes/loading_type').then(r => r.json()),
      fetch('/api/codes/loading_location').then(r => r.json())
    ]).then(([d, p, lt, pl]) => {
      setDealers(d);
      setProducts(p);
      setLoadTypes(lt || []);
      setPrefLocations(pl || []);
    }).catch(e => console.error(e));
  }, []);

  const handleDealerChange = async (e) => {
    const dealerId = e.target.value;
    setSelectedDealerId(dealerId);
    if (dealerId) {
      try {
        const r = await fetch(`/api/admin/parties/${dealerId}`);
        const p = await r.json();
        setParties(p);
        setPartyId('');
        setContactNumber('');
        setDeliveryAddress('');
      } catch (err) {
        console.error('Failed to load parties:', err);
      }
    } else {
      setParties([]);
    }
  };

  const handlePartyChange = (e) => {
    const pId = e.target.value;
    setPartyId(pId);
    const selected = parties.find(p => String(p.party_id) === pId);
    if (selected) {
      setContactNumber(selected.party_phone || '');
      setDeliveryAddress(selected.party_address || '');
    } else {
      setContactNumber('');
      setDeliveryAddress('');
    }
  };

  const updateItem = (idx, field, value) => {
    const newItems = [...items];
    newItems[idx][field] = value;
    setItems(newItems);
  };

  const removeItem = (idx) => {
    if (items.length > 1) {
      setItems(items.filter((_, i) => i !== idx));
    }
  };

  const addItem = () => {
    setItems([...items, { product_id: '', order_bags: '' }]);
  };

  const calculateQuantity = (bags) => {
    if (!bags) return 0;
    return parseFloat(((parseInt(bags) * 50) / 1000).toFixed(3));
  };

  const totalQty = items.reduce((sum, i) => sum + calculateQuantity(i.order_bags), 0);

  const submit = async (e) => {
    e.preventDefault();
    if (!selectedDealerId) {
      setError('Please select a dealer');
      return;
    }
    if (items.some(i => !i.product_id || !i.order_bags)) {
      setError('All products must have a value for bags');
      return;
    }
    setSaving(true); setError('');
    try {
      const res = await fetch('/api/admin/orders/on-behalf', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          items,
          dealer_id: parseInt(selectedDealerId),
          party_id: partyId ? parseInt(partyId) : null,
          load_type_code: loadType || null,
          preferred_location_code: prefLocation || null
        })
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Failed to place order');

      // Fetch complete order details to display in list
      const fullOrderRes = await fetch(`/api/dealer/orders/${data.order_id}`);
      const fullOrder = await fullOrderRes.json();
      onSaved(fullOrder);
      onClose();
    } catch (err) {
      setError(err.message);
    } finally {
      setSaving(false);
    }
  };

  return (
    <div className="modal d-block" tabIndex="-1" style={{ background: 'rgba(0,0,0,0.5)' }}>
      <div className="modal-dialog modal-dialog-centered modal-lg">
        <div className="modal-content">
          <form onSubmit={submit}>
            <div className="modal-header bg-primary text-white">
              <h5 className="modal-title">🛒 Create Order on Dealer's Behalf</h5>
              <button type="button" className="btn-close btn-close-white" onClick={onClose}></button>
            </div>
            <div className="modal-body">
              {error && <div className="alert alert-danger py-2">{error}</div>}

              {/* Dealer Selection */}
              <div className="mb-3">
                <label className="form-label fw-semibold">Dealer <span className="text-danger">*</span></label>
                <select className="form-select" value={selectedDealerId} onChange={handleDealerChange} required>
                  <option value="">Select a dealer...</option>
                  {dealers.map(d => <option key={d.dealer_id} value={d.dealer_id}>{d.dealer_name} ({d.dealer_code})</option>)}
                </select>
              </div>

              {/* Products Section */}
              <div className="mb-3">
                <label className="form-label fw-semibold">Products &amp; Quantities <span className="text-danger">*</span></label>
                <div className="table-responsive">
                  <table className="table table-sm table-bordered mb-0">
                    <thead className="table-light">
                      <tr>
                        <th>Product</th>
                        <th style={{ width: 100 }}>No. of Bags</th>
                        <th style={{ width: 100 }}>Qty (MT)</th>
                        <th style={{ width: 50, textAlign: 'center' }}>Action</th>
                      </tr>
                    </thead>
                    <tbody>
                      {items.map((item, idx) => (
                        <tr key={idx}>
                          <td>
                            <select
                              className="form-select form-select-sm"
                              value={item.product_id}
                              onChange={(e) => updateItem(idx, 'product_id', e.target.value)}
                              required>
                              <option value="">Select product...</option>
                              {products.map(p => <option key={p.product_id} value={p.product_id}>{p.product_name}</option>)}
                            </select>
                          </td>
                          <td>
                            <input
                              type="number"
                              min="1"
                              className="form-control form-control-sm"
                              value={item.order_bags}
                              onChange={(e) => updateItem(idx, 'order_bags', e.target.value)}
                              placeholder="0"
                              required />
                          </td>
                          <td className="align-middle fw-semibold">
                            {calculateQuantity(item.order_bags).toFixed(3)} MT
                          </td>
                          <td className="text-center align-middle">
                            <button
                              type="button"
                              className="btn btn-sm btn-outline-danger"
                              onClick={() => removeItem(idx)}
                              disabled={items.length === 1}>
                              ✕
                            </button>
                          </td>
                        </tr>
                      ))}
                    </tbody>
                    {items.length > 0 && (
                      <tfoot>
                        <tr className="table-secondary fw-bold">
                          <td colSpan={2} className="text-muted small">Total</td>
                          <td>{totalQty.toFixed(3)} MT</td>
                          <td></td>
                        </tr>
                      </tfoot>
                    )}
                  </table>
                </div>
                <button type="button" className="btn btn-sm btn-outline-primary mt-2" onClick={addItem}>
                  ➕ Add Product
                </button>
              </div>

              {/* Ship to Party */}
              <div className="mb-3">
                <label className="form-label fw-semibold">Ship to Party</label>
                <select className="form-select" value={partyId} onChange={handlePartyChange}>
                  <option value="">Select party...</option>
                  {parties.map(p => <option key={p.party_id} value={p.party_id}>{p.party_company_name}</option>)}
                </select>
              </div>

              {/* Contact Number */}
              <div className="mb-3">
                <label className="form-label fw-semibold">Contact Number</label>
                <input
                  type="text"
                  className="form-control"
                  value={contactNumber}
                  onChange={(e) => setContactNumber(e.target.value)}
                  placeholder="Auto-filled or enter manually"
                />
              </div>

              {/* Delivery Address */}
              <div className="mb-3">
                <label className="form-label fw-semibold">Delivery Address</label>
                <textarea
                  className="form-control"
                  rows="2"
                  value={deliveryAddress}
                  onChange={(e) => setDeliveryAddress(e.target.value)}
                  placeholder="Auto-filled or enter manually"
                ></textarea>
              </div>

              {/* Loading Type & Preferred Loading Location */}
              <div className="row g-3 mb-3">
                <div className="col-md-6">
                  <label className="form-label fw-semibold">Loading Type</label>
                  <select className="form-select" value={loadType} onChange={(e) => setLoadType(e.target.value)}>
                    <option value="">Select Loading Type</option>
                    {loadTypes.map(lt => <option key={lt.code} value={lt.code}>{lt.code_desc}</option>)}
                  </select>
                </div>
                <div className="col-md-6">
                  <label className="form-label fw-semibold">Preferred Loading Location</label>
                  <select className="form-select" value={prefLocation} onChange={(e) => setPrefLocation(e.target.value)}>
                    <option value="">Select Preferred Location</option>
                    {prefLocations.map(pl => <option key={pl.code} value={pl.code}>{pl.code_desc}</option>)}
                  </select>
                </div>
              </div>
            </div>
            <div className="modal-footer">
              <button type="button" className="btn btn-secondary" onClick={onClose}>Cancel</button>
              <button type="submit" className="btn btn-primary" disabled={saving || items.some(i => !i.product_id || !i.order_bags)}>
                {saving && <span className="spinner-border spinner-border-sm me-1"></span>}
                Create Order
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  );
}

function PlaceOrderModal({ onClose, onSaved }) {
  const [form, setForm] = useState(EMPTY_FORM);
  const [saving, setSaving] = useState(false);
  const [error, setError] = useState('');

  const submit = async (e) => {
    e.preventDefault();
    setSaving(true); setError('');
    try {
      const res = await fetch('/api/dealer/orders', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(form)
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Failed to place order');
      onSaved(data);
    } catch (err) {
      setError(err.message);
    } finally {
      setSaving(false);
    }
  };

  return (
    <div className="modal d-block" tabIndex="-1" style={{ background: 'rgba(0,0,0,0.5)' }}>
      <div className="modal-dialog modal-dialog-centered">
        <div className="modal-content">
          <form onSubmit={submit}>
            <div className="modal-header bg-primary text-white">
              <h5 className="modal-title">🛒 Place New Order</h5>
              <button type="button" className="btn-close btn-close-white" onClick={onClose}></button>
            </div>
            <div className="modal-body">
              {error && <div className="alert alert-danger py-2">{error}</div>}
              <div className="mb-3">
                <label className="form-label fw-semibold">Product Name <span className="text-danger">*</span></label>
                <input className="form-control" value={form.product_name}
                  onChange={e => setForm({ ...form, product_name: e.target.value })}
                  placeholder="e.g. Steel Pipes, TMT Bars" required />
              </div>
              <div className="row g-3 mb-3">
                <div className="col-8">
                  <label className="form-label fw-semibold">Quantity <span className="text-danger">*</span></label>
                  <input type="number" min="1" className="form-control" value={form.quantity}
                    onChange={e => setForm({ ...form, quantity: e.target.value })}
                    placeholder="Enter quantity" required />
                </div>
                <div className="col-4">
                  <label className="form-label fw-semibold">Unit</label>
                  <select className="form-select" value={form.unit}
                    onChange={e => setForm({ ...form, unit: e.target.value })}>
                    {UNITS.map(u => <option key={u}>{u}</option>)}
                  </select>
                </div>
              </div>
              <div className="mb-3">
                <label className="form-label fw-semibold">Delivery Location <span className="text-danger">*</span></label>
                <input className="form-control" value={form.delivery_location}
                  onChange={e => setForm({ ...form, delivery_location: e.target.value })}
                  placeholder="e.g. Mumbai - Godown" required />
              </div>
              <div className="mb-1">
                <label className="form-label fw-semibold">Remarks</label>
                <textarea className="form-control" rows="2" value={form.remarks}
                  onChange={e => setForm({ ...form, remarks: e.target.value })}
                  placeholder="Any special instructions…" />
              </div>
            </div>
            <div className="modal-footer">
              <button type="button" className="btn btn-secondary" onClick={onClose}>Cancel</button>
              <button type="submit" className="btn btn-primary" disabled={saving}>
                {saving && <span className="spinner-border spinner-border-sm me-1"></span>}
                Place Order
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  );
}

function App() {
  const getDefaultDates = () => {
    if (IS_ADMIN) return { start: '', end: '' };
    const end = new Date();
    const start = new Date();
    start.setDate(start.getDate() - 2);
    return {
      start: start.toISOString().slice(0, 10),
      end: end.toISOString().slice(0, 10),
    };
  };
  const defaults = getDefaultDates();

  const [orders, setOrders] = useState([]);
  const [loading, setLoading] = useState(true);
  const [search, setSearch] = useState('');
  const [statusFilter, setStatusFilter] = useState('ALL');
  const [startDate, setStartDate] = useState(defaults.start);
  const [endDate, setEndDate] = useState(defaults.end);
  const [selectedOrder, setSelectedOrder] = useState(null);
  const [showPlaceOrder, setShowPlaceOrder] = useState(false);
  const [holdOrder, setHoldOrder] = useState(null);
  const [toast, setToast] = useState({ msg: '', type: 'success' });
  const [sortCol, setSortCol] = useState('order_id');
  const [sortDir, setSortDir] = useState('desc');
  const [dealerLimit, setDealerLimit] = useState(null);
  const [showCreateForDealer, setShowCreateForDealer] = useState(false);
  const [showColumnPicker, setShowColumnPicker] = useState(false);
  const [visibleCols, setVisibleCols] = useState({
    dealer: IS_ADMIN,
    product: true,
    qty: true,
    party: true,
    loadType: true,
    prefLocation: true,
    orderDate: true,
    status: true,
    dispatch: true,
  });

  const toggleSort = (col) => {
    if (sortCol === col) {
      setSortDir(d => d === 'asc' ? 'desc' : 'asc');
    } else {
      setSortCol(col);
      setSortDir('asc');
    }
  };

  const toggleColumn = (col) => {
    setVisibleCols(prev => ({ ...prev, [col]: !prev[col] }));
  };

  const SortTh = ({ col, children, style }) => {
    const active = sortCol === col;
    return (
      <th style={{ cursor: 'pointer', userSelect: 'none', whiteSpace: 'nowrap', ...style }}
          onClick={() => toggleSort(col)}>
        {children}&nbsp;
        <span style={{ opacity: active ? 1 : 0.3, fontSize: '0.75em' }}>
          {active ? (sortDir === 'asc' ? '▲' : '▼') : '▲▼'}
        </span>
      </th>
    );
  };

  const notify = (msg, type = 'success') => {
    setToast({ msg, type });
    setTimeout(() => setToast({ msg: '' }), 4000);
  };

  const load = async (dateFilters = {}) => {
    setLoading(true);
    try {
      const params = new URLSearchParams();
      const effectiveStartDate = dateFilters.startDate ?? startDate;
      const effectiveEndDate = dateFilters.endDate ?? endDate;
      if (effectiveStartDate) params.set('startDate', effectiveStartDate);
      if (effectiveEndDate) params.set('endDate', effectiveEndDate);
      const endpoint = IS_ADMIN ? '/api/admin/orders' : '/api/dealer/orders';
      const r = await fetch(params.toString() ? `${endpoint}?${params.toString()}` : endpoint);
      if (!r.ok) throw new Error(await r.text());
      setOrders(await r.json());
    } catch (e) {
      notify(e.message, 'danger');
    } finally {
      setLoading(false);
    }
  };

  useEffect(() => {
    load();
    if (!IS_ADMIN) {
      fetch('/api/dealer/limit')
        .then(r => r.json())
        .then(data => setDealerLimit(data))
        .catch(err => console.error('Failed to load limit:', err));
    }
  }, []);

  const applyDateFilter = () => {
    if (startDate && endDate && startDate > endDate) {
      notify('Start Date cannot be later than End Date.', 'danger');
      return;
    }
    load();
  };

  const resetDateFilter = () => {
    const d = getDefaultDates();
    setStartDate(d.start);
    setEndDate(d.end);
    load({ startDate: d.start, endDate: d.end });
  };

  const changeStatus = async (orderId, newStatus, extra = {}) => {
    try {
      const res = await fetch(`/api/dealer/orders/${orderId}/status`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status: newStatus, ...extra })
      });
      const d = await res.json();
      if (!res.ok) throw new Error(d.error);
      notify(`Order #${orderId} → ${STATUS_CONFIG[newStatus]?.text}`);
      load();
    } catch(e) { notify(e.message, 'danger'); }
  };

  const handleDealerHold = async (reason) => {
    await changeStatus(holdOrder.order_id, 'ON_HOLD', { reason });
    setHoldOrder(null);
  };

  const counts = {
    total:       orders.length,
    orderPlaced: orders.filter(o => o.order_status === 'ORDER_PLACED').length,
    onHold:      orders.filter(o => o.order_status === 'ON_HOLD').length,
    dispatched:  orders.filter(o => o.order_status === 'DISPATCHED').length,
  };

  const filtered = orders.filter(o => {
    const matchSearch = (o.product_name + ' ' + o.delivery_location + ' ' + o.order_id)
      .toLowerCase().includes(search.toLowerCase());
    const matchStatus = statusFilter === 'ALL' || o.order_status === statusFilter;
    return matchSearch && matchStatus;
  });

  const sorted = [...filtered].sort((a, b) => {
    let av = a[sortCol] ?? '';
    let bv = b[sortCol] ?? '';
    // numeric sort for order_id and quantity
    if (sortCol === 'order_id' || sortCol === 'quantity') {
      av = Number(av); bv = Number(bv);
      return sortDir === 'asc' ? av - bv : bv - av;
    }
    // date sort for order_date
    if (sortCol === 'order_date') {
      av = new Date(av); bv = new Date(bv);
      return sortDir === 'asc' ? av - bv : bv - av;
    }
    // string sort
    av = av.toString().toLowerCase(); bv = bv.toString().toLowerCase();
    if (av < bv) return sortDir === 'asc' ? -1 : 1;
    if (av > bv) return sortDir === 'asc' ?  1 : -1;
    return 0;
  });

  const onOrderPlaced = (newOrder) => {
    setOrders(prev => [newOrder, ...prev]);
    setShowPlaceOrder(false);
    notify(`Order #${newOrder.order_id} placed successfully!`);
  };

  const exportExcel = () => {
    const data = filtered.map(o => ({
      'Order Id': o.order_id,
      'Dealer': o.dealer_name || '',
      'Product': o.product_name,
      'Quantity': `${o.quantity} ${o.unit}`,
      'Delivery Location': o.delivery_location,
      'Order Date': formatDateTime(o.order_date),
      'Status': o.order_status,
      'Vehicle No': o.dispatch ? o.dispatch.vehicle_no : '',
      'Driver Name': o.dispatch ? o.dispatch.driver_name : '',
      'Driver Phone': o.dispatch ? o.dispatch.driver_phone : '',
      'Dispatch Date': o.dispatch ? o.dispatch.dispatch_date : '',
      'Expected Delivery': o.dispatch ? o.dispatch.expected_delivery : '',
      'Actual Delivery': o.dispatch ? (o.dispatch.actual_delivery || '') : '',
      'Dispatch Status': o.dispatch ? o.dispatch.dispatch_status : '',
      'Remarks': o.remarks || '',
    }));
    const ws = XLSX.utils.json_to_sheet(data);
    const wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb, ws, IS_ADMIN ? 'All Orders' : 'My Orders');
    XLSX.writeFile(wb, IS_ADMIN ? 'All_Orders_Dispatch.xlsx' : 'My_Orders.xlsx');
  };

  return (
    <div>
      {toast.msg && (
        <div className={`alert alert-${toast.type} alert-dismissible mb-3`}>
          {toast.msg}
          <button className="btn-close" onClick={() => setToast({ msg: '' })}></button>
        </div>
      )}

      {/* Summary Cards */}
      <div className="row mb-2">
        <SummaryCard label="Total Orders"  value={counts.total}       icon="📋" borderColor="#0d6efd" />
        <SummaryCard label="Order Placed"  value={counts.orderPlaced} icon="🕐" borderColor="#fd7e14" />
        <SummaryCard label="On Hold"       value={counts.onHold}      icon="⏸️" borderColor="#e57373" />
        <SummaryCard label="Dispatched"    value={counts.dispatched}  icon="📦" borderColor="#198754" />
        {!IS_ADMIN && dealerLimit && (
          <div className="col-6 col-md-3 mb-3">
            <div className="card border-0 shadow-sm h-100" style={{ borderLeft: `4px solid ${dealerLimit.daily_limit > 0 && dealerLimit.percentage >= 80 ? '#dc3545' : '#198754'}` }}>
              <div className="card-body p-3">
                <div className="text-muted small mb-2">Daily Remaining</div>
                <div className="fs-5 fw-bold">{dealerLimit.remaining.toFixed(3)} MT</div>
                <div className="text-muted small mt-1">
                  {dealerLimit.daily_limit > 0 ? (
                    <>
                      Used: {dealerLimit.used_today.toFixed(3)} / {dealerLimit.daily_limit.toFixed(3)} ({dealerLimit.percentage.toFixed(0)}%)
                    </>
                  ) : (
                    'No limit set'
                  )}
                </div>
                {dealerLimit.percentage >= 80 && dealerLimit.daily_limit > 0 && (
                  <div className="alert alert-danger alert-sm mt-2 mb-0 py-1 px-2" style={{ fontSize: '0.8rem' }}>
                    ⚠️ 80% threshold reached
                  </div>
                )}
                {dealerLimit.admin_phone && (
                  <div className="mt-2 pt-2 border-top">
                    <a
                      href={`tel:${dealerLimit.admin_phone}`}
                      className="btn btn-sm btn-outline-primary w-100"
                      title="Call admin to request limit increase"
                    >
                      📞 Contact Admin
                    </a>
                  </div>
                )}
              </div>
            </div>
          </div>
        )}
      </div>

      {/* Orders Table */}
      <div className="card shadow-sm">
        <div className="card-header bg-white d-flex align-items-center justify-content-between py-3">
          <h5 className="mb-0 fw-semibold">{IS_ADMIN ? '📊 All Orders & Dispatch' : '📋 My Orders'}</h5>
          <div className="d-flex gap-2">
            <div className="dropdown position-relative">
              <button className="btn btn-outline-secondary btn-sm" onClick={() => setShowColumnPicker(!showColumnPicker)}>
                ⚙️ Columns
              </button>
              {showColumnPicker && (
                <div className="dropdown-menu d-block position-absolute" style={{ right: 0, minWidth: 200, zIndex: 1000 }}>
                  <div className="p-2">
                    {IS_ADMIN && (
                      <div className="form-check mb-2">
                        <input className="form-check-input" type="checkbox" id="col-dealer" checked={visibleCols.dealer} onChange={() => toggleColumn('dealer')} />
                        <label className="form-check-label" htmlFor="col-dealer">Dealer</label>
                      </div>
                    )}
                    <div className="form-check mb-2">
                      <input className="form-check-input" type="checkbox" id="col-product" checked={visibleCols.product} onChange={() => toggleColumn('product')} />
                      <label className="form-check-label" htmlFor="col-product">Product</label>
                    </div>
                    <div className="form-check mb-2">
                      <input className="form-check-input" type="checkbox" id="col-qty" checked={visibleCols.qty} onChange={() => toggleColumn('qty')} />
                      <label className="form-check-label" htmlFor="col-qty">Quantity</label>
                    </div>
                    <div className="form-check mb-2">
                      <input className="form-check-input" type="checkbox" id="col-party" checked={visibleCols.party} onChange={() => toggleColumn('party')} />
                      <label className="form-check-label" htmlFor="col-party">Party</label>
                    </div>
                    <div className="form-check mb-2">
                      <input className="form-check-input" type="checkbox" id="col-loadType" checked={visibleCols.loadType} onChange={() => toggleColumn('loadType')} />
                      <label className="form-check-label" htmlFor="col-loadType">Loading Type</label>
                    </div>
                    <div className="form-check mb-2">
                      <input className="form-check-input" type="checkbox" id="col-prefLocation" checked={visibleCols.prefLocation} onChange={() => toggleColumn('prefLocation')} />
                      <label className="form-check-label" htmlFor="col-prefLocation">Pref. Location</label>
                    </div>
                    <div className="form-check mb-2">
                      <input className="form-check-input" type="checkbox" id="col-orderDate" checked={visibleCols.orderDate} onChange={() => toggleColumn('orderDate')} />
                      <label className="form-check-label" htmlFor="col-orderDate">Order Date</label>
                    </div>
                    <div className="form-check mb-2">
                      <input className="form-check-input" type="checkbox" id="col-status" checked={visibleCols.status} onChange={() => toggleColumn('status')} />
                      <label className="form-check-label" htmlFor="col-status">Status</label>
                    </div>
                    <div className="form-check">
                      <input className="form-check-input" type="checkbox" id="col-dispatch" checked={visibleCols.dispatch} onChange={() => toggleColumn('dispatch')} />
                      <label className="form-check-label" htmlFor="col-dispatch">Dispatch</label>
                    </div>
                    <hr className="my-2" />
                    <button className="btn btn-sm btn-outline-primary w-100" onClick={() => setShowColumnPicker(false)}>Close</button>
                  </div>
                </div>
              )}
            </div>
            {IS_ADMIN && (
              <>
                <button className="btn btn-outline-success btn-sm" onClick={exportExcel}>
                  ⬇️ Download Excel
                </button>
                <button className="btn btn-info btn-sm" onClick={() => setShowCreateForDealer(true)}>
                  🛒 Create for Dealer
                </button>
              </>
            )}
            {!IS_ADMIN && (
              <a className="btn btn-primary btn-sm" href="/orders?action=new">
                🛒 Place New Order
              </a>
            )}
          </div>
        </div>
        <div className="card-body">
          <div className="row mb-3 g-2">
            <div className="col-md-3">
              <input className="form-control" placeholder="Search by product, location, order ID…"
                value={search} onChange={e => setSearch(e.target.value)} />
            </div>
            <div className="col-md-2">
              <input
                type="date"
                className="form-control"
                value={startDate}
                onChange={e => setStartDate(e.target.value)}
                aria-label="Start Date"
              />
            </div>
            <div className="col-md-2">
              <input
                type="date"
                className="form-control"
                value={endDate}
                onChange={e => setEndDate(e.target.value)}
                aria-label="End Date"
              />
            </div>
            <div className="col-md-2">
              <select className="form-select" value={statusFilter} onChange={e => setStatusFilter(e.target.value)}>
                <option value="ALL">All Statuses</option>
                {Object.entries(STATUS_CONFIG).map(([k, v]) =>
                  <option key={k} value={k}>{v.text}</option>
                )}
              </select>
            </div>
            <div className="col-md-2 d-flex gap-2">
              <button className="btn btn-outline-primary w-100" onClick={applyDateFilter}>
                Load
              </button>
              <button className="btn btn-outline-secondary" onClick={resetDateFilter} title={IS_ADMIN ? 'Clear date filter' : 'Reset to last 2 days'}>
                Reset
              </button>
            </div>
            {!IS_ADMIN && (
              <div className="col-12">
                <small className="text-muted">
                  Showing orders from the last 2 days. Select a start &amp; end date above and click <strong>Load</strong> to view historical orders.
                </small>
              </div>
            )}
            <div className="col-md-1 text-end text-muted small align-self-center">
              {sorted.length} order{sorted.length !== 1 ? 's' : ''}
            </div>
          </div>

          {loading ? (
            <div className="text-center py-5">
              <div className="spinner-border text-primary"></div>
              <p className="text-muted mt-2">Loading orders…</p>
            </div>
          ) : (
            <div className="table-responsive">
              <table className="table table-hover table-bordered align-middle mb-0">
                <thead className="table-light">
                  <tr>
                    <SortTh col="order_id" style={{ width: 90 }}>Order Id</SortTh>
                    {IS_ADMIN && visibleCols.dealer && <SortTh col="dealer_name">Dealer</SortTh>}
                    {visibleCols.product && <SortTh col="product_name">Product</SortTh>}
                    {visibleCols.qty && <SortTh col="quantity" style={{ width: 100 }}>Qty</SortTh>}
                    {visibleCols.party && <SortTh col="party_name">Party</SortTh>}
                    {visibleCols.loadType && <SortTh col="load_type_desc">Load Type</SortTh>}
                    {visibleCols.prefLocation && <SortTh col="preferred_location_desc">Pref. Location</SortTh>}
                    {visibleCols.orderDate && <SortTh col="order_date" style={{ width: 110 }}>Order Date</SortTh>}
                    {visibleCols.status && <th style={{ width: 130, textAlign: 'center' }}>Status</th>}
                    {visibleCols.dispatch && <th style={{ width: 120, textAlign: 'center' }}>Dispatch</th>}
                    <th style={{ width: 180, textAlign: 'center' }}>Action</th>
                  </tr>
                </thead>
                <tbody>
                  {sorted.length === 0 ? (
                    <tr><td colSpan={Object.values(visibleCols).filter(Boolean).length + (IS_ADMIN ? 2 : 1)} className="text-center text-muted py-4">No orders found</td></tr>
                  ) : sorted.map(o => (
                    <tr key={o.order_id}>
                      <td className="fw-semibold text-primary">#{o.order_id}</td>
                      {IS_ADMIN && visibleCols.dealer && <td className="text-muted small">{o.dealer_name || '—'}</td>}
                      {visibleCols.product && <td>{o.product_name}</td>}
                      {visibleCols.qty && <td>{o.quantity} {o.unit}</td>}
                      {visibleCols.party && <td>{o.party_name || <span className="text-muted">—</span>}</td>}
                      {visibleCols.loadType && <td>{o.load_type_desc || <span className="text-muted">—</span>}</td>}
                      {visibleCols.prefLocation && <td>{o.preferred_location_desc || <span className="text-muted">—</span>}</td>}
                      {visibleCols.orderDate && <td>{formatDateTime(o.order_date)}</td>}
                      {visibleCols.status && <td className="text-center"><StatusBadge status={o.order_status} /></td>}
                      {visibleCols.dispatch && <td className="text-center">
                        {o.dispatch ? (
                          <span className="text-success small fw-semibold">
                            🚛 {o.dispatch.vehicle_no}
                          </span>
                        ) : (
                          <span className="text-muted small">—</span>
                        )}
                      </td>}
                      <td className="text-center">
                        <div className="d-flex justify-content-center gap-2 flex-wrap">
                          <button className="btn btn-outline-primary btn-sm"
                            onClick={() => setSelectedOrder(o)}>
                            View
                          </button>
                          {o.dispatch && o.dispatch.driver_phone && (
                            <a
                              className="btn btn-outline-success btn-sm"
                              href={`/tracking?driver=${encodeURIComponent(o.dispatch.driver_phone)}&order=${o.order_id}`}
                            >
                              Track
                            </a>
                          )}
                          {IS_ADMIN && o.order_status === 'ORDER_PLACED' && (
                            <>
                              <button className="btn btn-success btn-sm" title="Accept this order" onClick={() => changeStatus(o.order_id, 'ACCEPTED')}>Accept</button>
                              <button className="btn btn-outline-secondary btn-sm" title="Put order on hold" onClick={() => changeStatus(o.order_id, 'ON_HOLD')}>On Hold</button>
                            </>
                          )}
                          {IS_ADMIN && o.order_status === 'ACCEPTED' && (
                            <button className="btn btn-primary btn-sm" title="Mark as dispatched" onClick={() => changeStatus(o.order_id, 'DISPATCHED')}>Dispatch</button>
                          )}
                          {IS_ADMIN && o.order_status === 'ON_HOLD' && o.on_hold_by !== 'DEALER' && (
                            <button className="btn btn-warning btn-sm" title="Reopen to Order Placed" onClick={() => changeStatus(o.order_id, 'ORDER_PLACED')}>Reopen</button>
                          )}
                          {IS_ADMIN && o.order_status === 'ON_HOLD' && o.on_hold_by === 'DEALER' && (
                            <span className="badge bg-secondary" title="Put on hold by dealer — only dealer can reopen">🔒 Dealer Hold</span>
                          )}
                          {!IS_ADMIN && o.order_status === 'ORDER_PLACED' && (
                            <button className="btn btn-outline-secondary btn-sm" title="Put this order on hold" onClick={() => setHoldOrder(o)}>On Hold</button>
                          )}
                          {!IS_ADMIN && o.order_status === 'ON_HOLD' && o.on_hold_by === 'DEALER' && (
                            <button className="btn btn-warning btn-sm" title="Reopen order" onClick={() => changeStatus(o.order_id, 'ORDER_PLACED')}>Reopen</button>
                          )}
                          {!IS_ADMIN && (o.order_status === 'ACCEPTED' || o.order_status === 'DISPATCHED') && (
                            <span className="text-muted small" title="Place a new order for extra units">🔒 Cannot edit — place a new order for extra units</span>
                          )}
                        </div>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </div>
      </div>

      {selectedOrder && <DispatchModal order={selectedOrder} onClose={() => setSelectedOrder(null)} />}
      {showPlaceOrder && <PlaceOrderModal onClose={() => setShowPlaceOrder(false)} onSaved={onOrderPlaced} />}
      {showCreateForDealer && <CreateForDealerModal onClose={() => setShowCreateForDealer(false)} onSaved={onOrderPlaced} />}
      {holdOrder && <OnHoldModal order={holdOrder} onConfirm={handleDealerHold} onClose={() => setHoldOrder(null)} requireReason={IS_ADMIN} />}
    </div>
  );
}

ReactDOM.createRoot(document.getElementById('app-root')).render(<App />);
</script>
<%- include('../partials/footer') %>
