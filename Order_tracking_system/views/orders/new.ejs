<%- include('../partials/header') %>

<nav aria-label="breadcrumb" class="mb-3">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
    <li class="breadcrumb-item"><a href="/orders">My Orders</a></li>
    <li class="breadcrumb-item active">Place New Order</li>
  </ol>
</nav>

<div class="row justify-content-center">
  <div class="col-lg-9">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
        <div>
          <h4 class="mb-1">New Order</h4>
          <div class="text-muted small">Add one or more products. Party, address &amp; loading details are common to all products.</div>
        </div>
        <a href="/orders" class="btn btn-outline-secondary btn-sm">Back to Orders</a>
      </div>
      <div class="card-body p-4">
        <div id="form-alert" class="alert d-none" role="alert"></div>

        <!-- Daily Limit Alert -->
        <div id="limit-info" class="alert alert-info d-none mb-4" role="alert">
          <div class="row g-2">
            <div class="col-md-6">
              <div><strong>Daily Limit:</strong> <span id="limit-value">—</span> MT</div>
            </div>
            <div class="col-md-6">
              <div><strong>Remaining:</strong> <span id="remaining-value" class="fw-bold">—</span> MT</div>
            </div>
            <div id="limit-warning" class="col-12 d-none">
              <div class="alert alert-danger py-1 px-2 mb-0">⚠️ <span id="warning-text"></span></div>
            </div>
            <div id="admin-contact" class="col-12 d-none">
              <small class="text-muted">Need to increase your limit? <a id="admin-phone-link" href="#">Contact Admin</a></small>
            </div>
          </div>
        </div>

        <form id="new-order-form" class="row g-3">

          <!-- ── Products Section ──────────────────────────────────── -->
          <div class="col-12">
            <div class="d-flex align-items-center justify-content-between mb-2">
              <label class="form-label fw-semibold mb-0">Products &amp; Quantities <span class="text-danger">*</span></label>
              <button type="button" id="add-item-btn" class="btn btn-sm btn-outline-primary">+ Add Product</button>
            </div>
            <div id="items-container">
              <!-- rows injected by JS -->
            </div>
          </div>

          <!-- ── Party Section ─────────────────────────────────────── -->
          <div class="col-12">
            <div class="d-flex align-items-center justify-content-between mb-2">
              <label class="form-label fw-semibold mb-0">Ship to Party</label>
              <div class="form-check form-switch mb-0">
                <input class="form-check-input" type="checkbox" id="new-party-toggle">
                <label class="form-check-label small" for="new-party-toggle">Add New Party</label>
              </div>
            </div>

            <div id="existing-party-section">
              <select id="party_select" class="form-select" required>
                <option value="">Loading parties…</option>
              </select>
              <input type="hidden" id="party_id" name="party_id">
            </div>

            <div id="new-party-section" class="d-none">
              <div class="row g-2">
                <div class="col-12">
                  <input id="new_party_name" type="text" class="form-control" placeholder="Party / Company Name" autocomplete="off">
                </div>
                <div class="col-12">
                  <input id="new_party_phone" type="text" class="form-control" placeholder="Phone Number">
                </div>
                <div class="col-12">
                  <input id="new_party_address" type="text" class="form-control" placeholder="Address">
                </div>
              </div>
            </div>
          </div>

          <div class="col-md-6">
            <label for="contact_number" class="form-label fw-semibold">Contact Number</label>
            <input id="contact_number" type="text" class="form-control" placeholder="Auto-filled or enter manually">
          </div>

          <div class="col-12">
            <label for="delivery_address" class="form-label fw-semibold">Delivery Address</label>
            <textarea id="delivery_address" class="form-control" rows="2" placeholder="Auto-filled or enter manually"></textarea>
          </div>

          <div class="col-md-6">
            <label for="load_type_code" class="form-label fw-semibold">Loading Type</label>
            <select id="load_type_code" class="form-select" required>
              <option value="">Loading…</option>
            </select>
          </div>

          <div class="col-md-6">
            <label for="preferred_location_code" class="form-label fw-semibold">Preferred Loading Location</label>
            <select id="preferred_location_code" class="form-select" required>
              <option value="">Loading…</option>
            </select>
          </div>

          <div class="col-12 d-flex gap-2 justify-content-end pt-2">
            <a href="/orders" class="btn btn-light border">Cancel</a>
            <button type="submit" class="btn btn-primary" id="submit-btn">Place Order</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
  let productsData = [];
  let dealerLimit = null;

  // ── Load dealer limit ────────────────────────────────────────────────────
  (async () => {
    try {
      const res = await fetch('/api/dealer/limit');
      dealerLimit = await res.json();
      const limtInfoDiv = document.getElementById('limit-info');
      if (dealerLimit.daily_limit > 0) {
        document.getElementById('limit-value').textContent = dealerLimit.daily_limit.toFixed(3);
        document.getElementById('remaining-value').textContent = dealerLimit.remaining.toFixed(3);
        limtInfoDiv.classList.remove('d-none');

        // Show admin contact if limit is low (≥70%)
        if (dealerLimit.percentage >= 70) {
          const adminContactDiv = document.getElementById('admin-contact');
          const adminPhoneLink = document.getElementById('admin-phone-link');
          if (dealerLimit.admin_phone) {
            adminPhoneLink.href = `tel:${dealerLimit.admin_phone}`;
            adminPhoneLink.textContent = dealerLimit.admin_phone;
            adminContactDiv.classList.remove('d-none');
          }
        }
      }
    } catch (e) {
      console.error('Failed to load limit:', e);
    }
  })();

  // ── Item rows ────────────────────────────────────────────────────────────
  function buildProductOptions() {
    const blank = '<option value="">Select Product</option>';
    return blank + productsData.map(p =>
      `<option value="${p.product_id}">${p.product_name}</option>`
    ).join('');
  }

  function updateRemoveButtons() {
    const rows = document.querySelectorAll('.item-row');
    rows.forEach(row => {
      row.querySelector('.remove-item').style.visibility = rows.length === 1 ? 'hidden' : 'visible';
    });
  }

  const KG_PER_BAG = 50;

  function createItemRow() {
    const div = document.createElement('div');
    div.className = 'item-row row g-2 mb-2 align-items-end p-2 border rounded bg-light';
    div.innerHTML = `
      <div class="col-md-5">
        <label class="form-label fw-semibold small mb-1">Product <span class="text-danger">*</span></label>
        <select class="form-select item-product" required>${buildProductOptions()}</select>
      </div>
      <div class="col-md-3">
        <label class="form-label fw-semibold small mb-1">No. of Bags <span class="text-danger">*</span></label>
        <input type="number" min="1" step="1" class="form-control item-bags" placeholder="e.g. 100" required>
      </div>
      <div class="col-md-3">
        <label class="form-label fw-semibold small mb-1">
          Quantity (MT)
          <span class="text-muted fw-normal" style="font-size:.75rem"> = bags × ${KG_PER_BAG}kg</span>
        </label>
        <input type="number" step="0.001" class="form-control item-qty bg-light" placeholder="Auto-calculated" readonly tabindex="-1">
      </div>
      <div class="col-md-1 d-flex align-items-end pb-1">
        <button type="button" class="btn btn-outline-danger btn-sm remove-item" style="visibility:hidden">×</button>
      </div>
    `;
    div.querySelector('.remove-item').addEventListener('click', () => {
      div.remove();
      updateRemoveButtons();
    });

    // Auto-calculate MT when bags changes
    div.querySelector('.item-bags').addEventListener('input', function () {
      const bags = parseInt(this.value, 10);
      const qtyField = div.querySelector('.item-qty');
      if (bags > 0) {
        qtyField.value = (bags * KG_PER_BAG / 1000).toFixed(3);
      } else {
        qtyField.value = '';
      }
    });

    return div;
  }

  // ── Load dropdowns ───────────────────────────────────────────────────────
  (async () => {
    // Products (needed before first row is created)
    try {
      const res = await fetch('/api/dealer/products');
      productsData = await res.json();
    } catch (e) {
      productsData = [];
    }
    // Add first item row
    document.getElementById('items-container').appendChild(createItemRow());

    document.getElementById('add-item-btn').addEventListener('click', () => {
      document.getElementById('items-container').appendChild(createItemRow());
      updateRemoveButtons();
    });
  })();

  // Loading Type
  (async () => {
    const sel = document.getElementById('load_type_code');
    try {
      const res = await fetch('/api/codes/loading_type');
      const codes = await res.json();
      sel.innerHTML = '<option value="">Select Loading Type</option>';
      codes.forEach(c => {
        const opt = document.createElement('option');
        opt.value = c.code;
        opt.textContent = c.code_desc;
        sel.appendChild(opt);
      });
    } catch (e) { sel.innerHTML = '<option value="">Failed to load</option>'; }
  })();

  // Preferred Loading Location (grouped)
  (async () => {
    const sel = document.getElementById('preferred_location_code');
    try {
      const res = await fetch('/api/codes/loading_location');
      const codes = await res.json();
      sel.innerHTML = '<option value="">Select Preferred Location</option>';
      const groups = {};
      codes.forEach(c => {
        const grp = c.code_label || 'Other';
        if (!groups[grp]) groups[grp] = [];
        groups[grp].push(c);
      });
      Object.entries(groups).forEach(([label, items]) => {
        const og = document.createElement('optgroup');
        og.label = label.charAt(0) + label.slice(1).toLowerCase();
        items.forEach(c => {
          const opt = document.createElement('option');
          opt.value = c.code;
          opt.textContent = c.code_desc;
          og.appendChild(opt);
        });
        sel.appendChild(og);
      });
    } catch (e) { sel.innerHTML = '<option value="">Failed to load</option>'; }
  })();

  // ── Party logic ──────────────────────────────────────────────────────────
  let partiesData = [];

  (async () => {
    const sel = document.getElementById('party_select');
    try {
      const res = await fetch('/api/dealer/parties');
      partiesData = await res.json();
      sel.innerHTML = '<option value="">Select Party</option>';
      if (partiesData.length === 0) {
        sel.innerHTML = '<option value="">No parties found — add a new one</option>';
      } else {
        partiesData.forEach(p => {
          const opt = document.createElement('option');
          opt.value = p.party_id;
          opt.textContent = p.party_company_name;
          sel.appendChild(opt);
        });
      }
    } catch (e) { sel.innerHTML = '<option value="">Failed to load parties</option>'; }
  })();

  document.getElementById('party_select').addEventListener('change', function () {
    const selected = partiesData.find(p => String(p.party_id) === this.value);
    document.getElementById('party_id').value = this.value;
    document.getElementById('contact_number').value  = selected ? (selected.party_phone   || '') : '';
    document.getElementById('delivery_address').value = selected ? (selected.party_address || '') : '';
  });

  document.getElementById('new_party_phone').addEventListener('input', function () {
    document.getElementById('contact_number').value = this.value;
  });
  document.getElementById('new_party_address').addEventListener('input', function () {
    document.getElementById('delivery_address').value = this.value;
  });

  document.getElementById('new-party-toggle').addEventListener('change', function () {
    const isNew = this.checked;
    document.getElementById('existing-party-section').classList.toggle('d-none', isNew);
    document.getElementById('new-party-section').classList.toggle('d-none', !isNew);
    document.getElementById('party_select').required = !isNew;
    if (isNew) {
      document.getElementById('party_id').value = '';
      document.getElementById('contact_number').value  = '';
      document.getElementById('delivery_address').value = '';
    } else {
      document.getElementById('party_select').dispatchEvent(new Event('change'));
    }
  });

  // ── Form submit ──────────────────────────────────────────────────────────
  const form      = document.getElementById('new-order-form');
  const submitBtn = document.getElementById('submit-btn');
  const alertBox  = document.getElementById('form-alert');

  function showAlert(type, message) {
    alertBox.className = `alert alert-${type}`;
    alertBox.textContent = message;
  }

  form.addEventListener('submit', async (event) => {
    event.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';
    alertBox.className = 'alert d-none';

    const isNew = document.getElementById('new-party-toggle').checked;
    let party_id = document.getElementById('party_id').value;

    try {
      // Collect and validate item rows
      const itemRows = document.querySelectorAll('.item-row');
      const items = [];
      for (let idx = 0; idx < itemRows.length; idx++) {
        const row = itemRows[idx];
        const product_id = row.querySelector('.item-product').value;
        const bags       = row.querySelector('.item-bags').value.trim();
        if (!product_id) throw new Error(`Row ${idx + 1}: please select a product`);
        if (!bags || parseInt(bags, 10) < 1) throw new Error(`Row ${idx + 1}: number of bags is required`);
        const order_bags     = parseInt(bags, 10);
        const order_quantity = parseFloat((order_bags * KG_PER_BAG / 1000).toFixed(3));
        items.push({ product_id: parseInt(product_id), order_bags, order_quantity });
      }
      if (items.length === 0) throw new Error('At least one product is required');

      // Create new party if needed
      if (isNew) {
        const newName = document.getElementById('new_party_name').value.trim();
        if (!newName) throw new Error('Party name is required.');
        const pRes = await fetch('/api/dealer/parties', {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify({
            party_company_name: newName,
            party_phone:        document.getElementById('new_party_phone').value.trim(),
            party_address:      document.getElementById('new_party_address').value.trim(),
          }),
        });
        const pData = await pRes.json();
        if (!pRes.ok) throw new Error(pData.error || 'Failed to create party');
        party_id = pData.party_id;
      } else {
        if (!party_id) throw new Error('Please select a party.');
      }

      // Check total quantity against limit
      const totalQty = items.reduce((sum, item) => sum + item.order_quantity, 0);
      if (dealerLimit && dealerLimit.daily_limit > 0) {
        if (totalQty > dealerLimit.remaining) {
          const contactMsg = dealerLimit.admin_phone ? ` Call Admin: ${dealerLimit.admin_phone}` : '';
          throw new Error(`Order quantity (${totalQty.toFixed(3)} MT) exceeds remaining daily limit (${dealerLimit.remaining.toFixed(3)} MT). ${dealerLimit.percentage.toFixed(0)}% of limit already used. Contact Admin to increase your limit.${contactMsg}`);
        }
        if (totalQty >= dealerLimit.remaining * 0.8) {
          const proceed = confirm(`⚠️ Warning: This order will use ${(totalQty / dealerLimit.daily_limit * 100).toFixed(0)}% of your daily limit. Continue?`);
          if (!proceed) throw new Error('Order cancelled by user');
        }
      }

      const payload = {
        items,
        party_id,
        load_type_code:          document.getElementById('load_type_code').value          || null,
        preferred_location_code: document.getElementById('preferred_location_code').value || null,
      };

      const response = await fetch('/api/dealer/orders', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify(payload),
      });

      const data = await response.json();
      if (!response.ok) {
        let errorMsg = data.error || 'Failed to create order';
        if (data.error && dealerLimit && dealerLimit.admin_phone) {
          errorMsg += ` | Contact Admin: ${dealerLimit.admin_phone}`;
        }
        throw new Error(errorMsg);
      }

      showAlert('success', `Order #${data.order_id} placed successfully.`);
      window.setTimeout(() => { window.location.href = '/orders'; }, 800);
    } catch (error) {
      showAlert('danger', error.message);
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Place Order';
    }
  });
</script>

<%- include('../partials/footer') %>
