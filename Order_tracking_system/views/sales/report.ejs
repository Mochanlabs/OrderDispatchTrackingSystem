<%- include('../partials/header') %>
<script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/react@18/umd/react.development.js"></script>
<script src="https://cdn.jsdelivr.net/npm/react-dom@18/umd/react-dom.development.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@babel/standalone/babel.min.js"></script>

<nav aria-label="breadcrumb" class="mb-3">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
    <li class="breadcrumb-item active">Sales Report</li>
  </ol>
</nav>
<div id="app-root"></div>

<script type="text/babel">
const { useState, useEffect, useRef } = React;

function SalesReport() {
  const [dealers, setDealers] = useState([]);
  const [products, setProducts] = useState([]);
  const [daily, setDaily] = useState([]);
  const [loading, setLoading] = useState(true);
  const [year, setYear] = useState(new Date().getFullYear());
  const [month, setMonth] = useState(new Date().getMonth() + 1);
  const [expanded, setExpanded] = useState({});
  const [dealerSearch, setDealerSearch] = useState('');
  const [monthlyTrend, setMonthlyTrend] = useState([]);
  const chartRef = useRef(null);
  const chartInstance = useRef(null);
  const trendChartRef = useRef(null);
  const trendChartInstance = useRef(null);
  const dealersChartRef = useRef(null);
  const dealersChartInstance = useRef(null);

  const monthNames = ['January', 'February', 'March', 'April', 'May', 'June',
    'July', 'August', 'September', 'October', 'November', 'December'];

  const loadReport = async (y, m) => {
    setLoading(true);
    try {
      const r = await fetch(`/api/sales/reports/monthly?year=${y}&month=${m}`, { credentials: 'include' });
      if (!r.ok) throw new Error(await r.text());
      const data = await r.json();
      setDealers(data.dealers);
      setProducts(data.products);
      setDaily(data.daily);
      renderChart(data.dealers);
    } catch (e) {
      console.error(e.message);
    } finally {
      setLoading(false);
    }
  };

  const renderChart = (dealerData) => {
    if (!chartRef.current) return;
    if (chartInstance.current) chartInstance.current.destroy();

    const ctx = chartRef.current.getContext('2d');
    chartInstance.current = new Chart(ctx, {
      type: 'bar',
      data: {
        labels: dealerData.map(d => d.dealer_name),
        datasets: [{
          label: 'Total Quantity (MT)',
          data: dealerData.map(d => parseFloat(d.total_qty) || 0),
          backgroundColor: '#198754',
          borderColor: '#0d6efd',
          borderWidth: 1,
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        plugins: {
          legend: { position: 'top' },
          title: { display: true, text: `Sales Report — ${monthNames[month - 1]} ${year}` }
        },
        scales: {
          y: { beginAtZero: true, title: { display: true, text: 'Quantity (MT)' } }
        }
      }
    });
  };

  const loadAnnualTrend = async (y) => {
    try {
      const r = await fetch(`/api/sales/reports/annual?year=${y}`, { credentials: 'include' });
      if (!r.ok) throw new Error(await r.text());
      const data = await r.json();
      setMonthlyTrend(data.months || []);
    } catch (e) {
      console.error('Failed to load annual trend:', e.message);
    }
  };

  useEffect(() => {
    loadReport(year, month);
    loadAnnualTrend(year);
  }, [year, month]);

  useEffect(() => {
    if (dealers.length === 0 || !dealersChartRef.current || !window.Chart) return;
    if (dealersChartInstance.current) dealersChartInstance.current.destroy();

    try {
      const topFive = dealers.slice(0, 5).sort((a, b) => parseFloat(b.total_qty) - parseFloat(a.total_qty));
      const ctx = dealersChartRef.current.getContext('2d');
      dealersChartInstance.current = new window.Chart(ctx, {
        type: 'bar',
        data: {
          labels: topFive.map(d => d.dealer_name),
          datasets: [{
            label: 'Total Quantity (MT)',
            data: topFive.map(d => parseFloat(d.total_qty) || 0),
            backgroundColor: '#0dcaf0',
            borderColor: '#0d6efd',
            borderWidth: 1,
          }]
        },
        options: {
          indexAxis: 'y',
          responsive: true,
          maintainAspectRatio: true,
          plugins: { legend: { display: false } },
          scales: { x: { beginAtZero: true, title: { display: true, text: 'Quantity (MT)' } } }
        }
      });
    } catch (e) {
      console.error('Error rendering dealers chart:', e);
    }
  }, [dealers]);

  useEffect(() => {
    if (monthlyTrend.length === 0 || !trendChartRef.current || !window.Chart) return;
    if (trendChartInstance.current) trendChartInstance.current.destroy();

    try {
      const ctx = trendChartRef.current.getContext('2d');
      trendChartInstance.current = new window.Chart(ctx, {
        type: 'line',
        data: {
          labels: monthlyTrend.map(m => m.month_name),
          datasets: [{
            label: 'Monthly Sales (MT)',
            data: monthlyTrend.map(m => parseFloat(m.total_qty) || 0),
            borderColor: '#198754',
            backgroundColor: 'rgba(25, 135, 84, 0.1)',
            borderWidth: 2,
            tension: 0.4,
            fill: true,
            pointRadius: 4,
            pointHoverRadius: 6,
            pointBackgroundColor: '#198754'
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: true,
          plugins: { legend: { position: 'top' } },
          scales: { y: { beginAtZero: true, title: { display: true, text: 'Quantity (MT)' } } }
        }
      });
    } catch (e) {
      console.error('Error rendering trend chart:', e);
    }
  }, [monthlyTrend]);

  const handlePrevMonth = () => {
    if (month === 1) {
      setYear(year - 1);
      setMonth(12);
    } else {
      setMonth(month - 1);
    }
  };

  const handleNextMonth = () => {
    if (month === 12) {
      setYear(year + 1);
      setMonth(1);
    } else {
      setMonth(month + 1);
    }
  };

  const toggleExpand = (dealerId) => {
    setExpanded(prev => ({ ...prev, [dealerId]: !prev[dealerId] }));
  };

  const exportExcel = () => {
    // Dealer Summary Sheet
    // Column Mappings:
    // - Dealer: dealers.dealer_name
    // - Code: first user.user_login_name (from odts.users table, sorted by user_id)
    // - Total Orders/Qty/Status Counts: from dealer_orders aggregation
    const dealerData = dealers.map(d => ({
      'Dealer': d.dealer_name,
      'Code': d.user_login_name || '',
      'Total Orders': d.total_orders,
      'Total Qty (MT)': parseFloat(d.total_qty).toFixed(2),
      'Placed': d.placed_count,
      'Accepted': d.accepted_count,
      'Dispatched': d.dispatched_count,
      'On Hold': d.on_hold_count
    }));

    const productData = products.map(p => ({
      'Dealer ID': p.dealer_id,
      'Product': p.product_name,
      'Orders': p.order_count,
      'Qty (MT)': parseFloat(p.total_qty).toFixed(2)
    }));

    // Daily Breakdown Sheet
    // Column Mappings:
    // - Dealer ID: dealer_orders.dealer_id
    // - Date: DATE(dealer_orders.order_date)
    // - Order Date: MIN(dealer_orders.order_date) [timestamp with full details]
    const dailyData = daily.map(d => ({
      'Dealer ID': d.dealer_id,
      'Date': d.order_day,
      'Order Date': d.order_date ? new Date(d.order_date).toLocaleString('en-IN') : d.order_day,
      'Orders': d.order_count,
      'Qty (MT)': parseFloat(d.total_qty).toFixed(2)
    }));

    const ws1 = XLSX.utils.json_to_sheet(dealerData);
    const ws2 = XLSX.utils.json_to_sheet(productData);
    const ws3 = XLSX.utils.json_to_sheet(dailyData);
    const wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb, ws1, 'Dealer Summary');
    XLSX.utils.book_append_sheet(wb, ws2, 'Product Breakdown');
    XLSX.utils.book_append_sheet(wb, ws3, 'Daily Breakdown');
    XLSX.writeFile(wb, `Sales_Report_${monthNames[month - 1]}_${year}.xlsx`);
  };

  const totalDealer = dealers.length;
  const totalOrders = dealers.reduce((sum, d) => sum + d.total_orders, 0);
  const totalQty = dealers.reduce((sum, d) => sum + parseFloat(d.total_qty || 0), 0);

  const getDealerProducts = (dealerId) => products.filter(p => p.dealer_id === dealerId);
  const getDealerDaily = (dealerId) => daily.filter(d => d.dealer_id === dealerId);

  return (
    <div>
      {/* Header & Controls */}
      <div className="card shadow-sm mb-4">
        <div className="card-header bg-white py-3">
          <div className="d-flex flex-column flex-lg-row align-items-start align-lg-center justify-content-between gap-2">
            <h5 className="mb-0 fw-semibold">📊 Monthly Sales Report</h5>
            <div className="d-flex gap-2 align-items-center flex-wrap justify-content-between justify-lg-content-end w-100">
              <button className="btn btn-outline-secondary btn-sm" onClick={handlePrevMonth}>← Prev</button>
              <span className="fw-semibold text-center" style={{ minWidth: 140 }}>
                {monthNames[month - 1]} {year}
              </span>
              <button className="btn btn-outline-secondary btn-sm" onClick={handleNextMonth}>Next →</button>
              <button className="btn btn-success btn-sm ms-auto ms-lg-0" onClick={exportExcel}>📥 Export</button>
            </div>
          </div>
        </div>
      </div>

      {/* Summary Cards */}
      <div className="row g-3 mb-3">
        <div className="col-6 col-sm-6 col-md-3">
          <div className="card border-0 shadow-sm h-100">
            <div className="card-body p-3">
              <div className="text-muted small mb-1">Total Dealers</div>
              <div className="fs-5 fw-bold">{totalDealer}</div>
            </div>
          </div>
        </div>
        <div className="col-6 col-sm-6 col-md-3">
          <div className="card border-0 shadow-sm h-100">
            <div className="card-body p-3">
              <div className="text-muted small mb-1">Total Orders</div>
              <div className="fs-5 fw-bold">{totalOrders}</div>
            </div>
          </div>
        </div>
        <div className="col-12 col-md-6">
          <div className="card border-0 shadow-sm h-100">
            <div className="card-body p-3">
              <div className="text-muted small mb-1">Total Quantity</div>
              <div className="fs-5 fw-bold">{totalQty.toFixed(2)} MT</div>
            </div>
          </div>
        </div>
      </div>

      {/* Top Dealers & Monthly Trend */}
      <div className="row g-3 mb-4">
        <div className="col-12 col-lg-6">
          <div className="card shadow-sm">
            <div className="card-header bg-white py-3">
              <h6 className="mb-0 fw-semibold">🏆 Top 5 Dealers (This Month)</h6>
            </div>
            <div className="card-body">
              {loading ? (
                <div className="text-center py-4"><div className="spinner-border spinner-border-sm"></div></div>
              ) : dealers.length > 0 ? (
                <canvas ref={dealersChartRef} style={{ maxHeight: '300px' }}></canvas>
              ) : (
                <div className="text-center text-muted py-4">No dealer data</div>
              )}
            </div>
          </div>
        </div>
        <div className="col-12 col-lg-6">
          <div className="card shadow-sm">
            <div className="card-header bg-white py-3">
              <h6 className="mb-0 fw-semibold">📈 Monthly Sales Trend (This Year)</h6>
            </div>
            <div className="card-body">
              {monthlyTrend.length > 0 ? (
                <canvas ref={trendChartRef} style={{ maxHeight: '300px' }}></canvas>
              ) : (
                <div className="text-center text-muted py-4">No trend data</div>
              )}
            </div>
          </div>
        </div>
      </div>

      {/* Table */}
      <div className="card shadow-sm">
        <div className="card-header bg-white py-3">
          <h5 className="mb-0 fw-semibold">📋 Sales by Dealer</h5>
        </div>
        <div className="card-body">
          {!loading && dealers.length > 0 && (
            <div className="mb-3">
              <input
                type="text"
                className="form-control"
                placeholder="Search by dealer name or code…"
                value={dealerSearch}
                onChange={e => setDealerSearch(e.target.value)}
              />
            </div>
          )}
          {loading ? (
            <div className="text-center py-5">
              <div className="spinner-border text-primary"></div>
              <p className="text-muted mt-2">Loading report…</p>
            </div>
          ) : dealers.length === 0 ? (
            <div className="text-center text-muted py-5">No data for this period</div>
          ) : (
            <div className="table-responsive">
              <table className="table table-hover table-bordered align-middle mb-0" style={{ fontSize: '0.85rem' }}>
                <thead className="table-light">
                  <tr>
                    <th style={{ width: 35, minWidth: 35 }}></th>
                    <th style={{ minWidth: 120 }}>Dealer</th>
                    <th style={{ minWidth: 60, textAlign: 'center' }}>Code</th>
                    <th style={{ minWidth: 70, textAlign: 'center' }}>Orders</th>
                    <th style={{ minWidth: 70, textAlign: 'center' }}>Qty (MT)</th>
                    <th style={{ minWidth: 50, textAlign: 'center' }}>Placed</th>
                    <th style={{ minWidth: 50, textAlign: 'center' }}>Accepted</th>
                    <th style={{ minWidth: 50, textAlign: 'center' }}>Dispatched</th>
                    <th style={{ minWidth: 50, textAlign: 'center' }}>On Hold</th>
                  </tr>
                </thead>
                <tbody>
                  {dealers.filter(d => {
                    const searchLower = dealerSearch.toLowerCase();
                    return d.dealer_name.toLowerCase().includes(searchLower) ||
                           (d.user_login_name && d.user_login_name.toLowerCase().includes(searchLower));
                  }).map(d => (
                    <React.Fragment key={d.dealer_id}>
                      <tr>
                        <td style={{ cursor: 'pointer', textAlign: 'center' }} onClick={() => toggleExpand(d.dealer_id)}>
                          <span style={{ fontSize: '1.2rem' }}>{expanded[d.dealer_id] ? '▼' : '▶'}</span>
                        </td>
                        <td className="fw-semibold">{d.dealer_name}</td>
                        <td className="text-muted small">{d.user_login_name || '—'}</td>
                        <td className="text-center">{d.total_orders}</td>
                        <td className="text-center fw-semibold">{parseFloat(d.total_qty).toFixed(2)}</td>
                        <td className="text-center text-primary">{d.placed_count}</td>
                        <td className="text-center text-info">{d.accepted_count}</td>
                        <td className="text-center text-success">{d.dispatched_count}</td>
                        <td className="text-center text-danger">{d.on_hold_count}</td>
                      </tr>
                      {expanded[d.dealer_id] && (
                        <tr>
                          <td colSpan="9" className="bg-light">
                            <div className="row g-3 mt-2 mb-2">
                              <div className="col-12 col-md-6">
                                <strong className="mb-2 d-block">By Product:</strong>
                                <div className="table-responsive">
                                  <table className="table table-sm table-bordered mb-0" style={{ fontSize: '0.8rem' }}>
                                    <thead className="table-light">
                                      <tr>
                                        <th style={{ minWidth: 100 }}>Product</th>
                                        <th style={{ minWidth: 50, textAlign: 'center' }}>Orders</th>
                                        <th style={{ minWidth: 60, textAlign: 'center' }}>Qty (MT)</th>
                                      </tr>
                                    </thead>
                                    <tbody>
                                      {getDealerProducts(d.dealer_id).length > 0 ? (
                                        getDealerProducts(d.dealer_id).map((p, idx) => (
                                          <tr key={idx}>
                                            <td>{p.product_name}</td>
                                            <td className="text-center">{p.order_count}</td>
                                            <td className="text-center">{parseFloat(p.total_qty).toFixed(2)}</td>
                                          </tr>
                                        ))
                                      ) : (
                                        <tr><td colSpan="3" className="text-muted text-center">No products</td></tr>
                                      )}
                                    </tbody>
                                  </table>
                                </div>
                              </div>
                              <div className="col-12 col-md-6">
                                <strong className="mb-2 d-block">By Day:</strong>
                                <div className="table-responsive">
                                  <table className="table table-sm table-bordered mb-0" style={{ fontSize: '0.8rem' }}>
                                    <thead className="table-light">
                                      <tr>
                                        <th style={{ minWidth: 90 }}>Date</th>
                                        <th style={{ minWidth: 50, textAlign: 'center' }}>Orders</th>
                                        <th style={{ minWidth: 60, textAlign: 'center' }}>Qty (MT)</th>
                                      </tr>
                                    </thead>
                                    <tbody>
                                      {getDealerDaily(d.dealer_id).length > 0 ? (
                                        getDealerDaily(d.dealer_id).map((dy, idx) => (
                                          <tr key={idx}>
                                            <td>{dy.order_day}</td>
                                            <td className="text-center">{dy.order_count}</td>
                                            <td className="text-center">{parseFloat(dy.total_qty).toFixed(2)}</td>
                                          </tr>
                                        ))
                                      ) : (
                                        <tr><td colSpan="3" className="text-muted text-center">No orders</td></tr>
                                      )}
                                    </tbody>
                                  </table>
                                </div>
                              </div>
                            </div>
                          </td>
                        </tr>
                      )}
                    </React.Fragment>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </div>
      </div>
    </div>
  );
}

ReactDOM.createRoot(document.getElementById('app-root')).render(<SalesReport />);
</script>
<%- include('../partials/footer') %>
