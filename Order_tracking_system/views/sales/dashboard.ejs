<%- include('../partials/header') %>
<script src="https://cdn.jsdelivr.net/npm/react@18/umd/react.development.js"></script>
<script src="https://cdn.jsdelivr.net/npm/react-dom@18/umd/react-dom.development.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@babel/standalone/babel.min.js"></script>

<nav aria-label="breadcrumb" class="mb-3">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
    <li class="breadcrumb-item active">Sales Dashboard</li>
  </ol>
</nav>
<div id="app-root"></div>

<style>
  .count-card {
    cursor: pointer !important;
    transition: all 0.2s ease !important;
  }
  .count-card:hover {
    transform: translateY(-4px) !important;
    box-shadow: 0 8px 16px rgba(0,0,0,0.15) !important;
  }
  .count-card.disabled {
    cursor: default !important;
  }
  .count-card.disabled:hover {
    transform: none !important;
    box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075) !important;
  }
</style>

<script type="text/babel">
const { useState, useEffect, useRef } = React;

const STATUS_CONFIG = {
  ORDER_PLACED: { text: 'Order Placed', icon: '🕐', bg: '#fd7e14', tc: '#fff' },
  ACCEPTED:     { text: 'Accepted',     icon: '✅', bg: '#0dcaf0', tc: '#000' },
  DISPATCHED:   { text: 'Dispatched',   icon: '📦', bg: '#198754', tc: '#fff' },
  ON_HOLD:      { text: 'On Hold',      icon: '⏸️', bg: '#e57373', tc: '#fff' },
};

function formatDateTime(value) {
  if (!value) return '—';
  const dt = new Date(value);
  if (Number.isNaN(dt.getTime())) return value;
  return new Intl.DateTimeFormat('en-IN', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
    second: '2-digit',
    hour12: true,
  }).format(dt);
}

function calculateExecutionTime(orderDate) {
  if (!orderDate) return '—';
  const now = new Date();
  const order = new Date(orderDate);
  const diffMs = now - order;
  const diffMins = Math.floor(diffMs / 60000);
  const diffHours = Math.floor(diffMs / 3600000);
  const diffDays = Math.floor(diffMs / 86400000);

  if (diffDays > 0) return `${diffDays}d ${diffHours % 24}h`;
  if (diffHours > 0) return `${diffHours}h ${diffMins % 60}m`;
  return `${diffMins}m`;
}

function StatusBadge({ status }) {
  const cfg = STATUS_CONFIG[status] || { bg: '#6c757d', tc: '#fff', text: status };
  return (
    <span className="badge" style={{ background: cfg.bg, color: cfg.tc }}>
      {cfg.icon} {cfg.text}
    </span>
  );
}

function StatusDealersModal({ orders, status, onSelectDealer, onClose }) {
  const statusOrders = status === 'TOTAL' ? orders : orders.filter(o => o.order_status === status);
  const dealerMap = {};

  statusOrders.forEach(o => {
    if (!dealerMap[o.dealer_id]) {
      dealerMap[o.dealer_id] = {
        dealer_id: o.dealer_id,
        dealer_name: o.dealer_name,
        count: 0,
      };
    }
    dealerMap[o.dealer_id].count++;
  });

  const dealers = Object.values(dealerMap).sort((a, b) => b.count - a.count);
  const statusConfig = STATUS_CONFIG[status] || { text: status, bg: '#6c757d', icon: '📊' };

  return (
    <div className="modal d-block" tabIndex="-1" style={{ background: 'rgba(0,0,0,0.55)' }}>
      <div className="modal-dialog modal-dialog-centered">
        <div className="modal-content">
          <div className="modal-header" style={{ background: statusConfig.bg, color: statusConfig.tc }}>
            <h5 className="modal-title">{statusConfig.icon} {statusConfig.text || 'Total'} Orders by Dealer</h5>
            <button type="button" className="btn-close" style={{filter: 'brightness(0) invert(1)'}} onClick={onClose}></button>
          </div>
          <div className="modal-body">
            {dealers.length === 0 ? (
              <p className="text-muted text-center py-3">No orders found</p>
            ) : (
              <div className="list-group">
                {dealers.map(dealer => (
                  <button
                    key={dealer.dealer_id}
                    type="button"
                    className="list-group-item list-group-item-action"
                    onClick={() => onSelectDealer(dealer.dealer_id)}
                  >
                    <div className="d-flex justify-content-between align-items-start">
                      <div className="text-start">
                        <div className="fw-semibold">{dealer.dealer_name}</div>
                      </div>
                      <span className="badge bg-info">{dealer.count}</span>
                    </div>
                  </button>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  );
}

function StatusOrdersModal({ orders, status, dealerId, onClose, onBack, onViewOrder }) {
  const statusOrders = status === 'TOTAL'
    ? orders.filter(o => o.dealer_id === dealerId)
    : orders.filter(o => o.dealer_id === dealerId && o.order_status === status);

  const dealerName = statusOrders[0]?.dealer_name || `Dealer #${dealerId}`;
  const statusConfig = STATUS_CONFIG[status] || { text: status, bg: '#6c757d', icon: '📊' };

  return (
    <div className="modal d-block" tabIndex="-1" style={{ background: 'rgba(0,0,0,0.55)' }}>
      <div className="modal-dialog modal-dialog-centered modal-lg">
        <div className="modal-content">
          <div className="modal-header d-flex align-items-center justify-content-between" style={{ background: statusConfig.bg, color: statusConfig.tc }}>
            <div className="d-flex align-items-center gap-2">
              {onBack && (
                <button type="button" className="btn btn-sm btn-light" onClick={onBack} title="Go back to dealers">
                  ← Back
                </button>
              )}
              <h5 className="modal-title mb-0">{statusConfig.icon} {statusConfig.text || 'Total'} — {dealerName}</h5>
            </div>
            <button type="button" className="btn-close" style={{filter: 'brightness(0) invert(1)'}} onClick={onClose}></button>
          </div>
          <div className="modal-body" style={{ maxHeight: '70vh', overflowY: 'auto' }}>
            {statusOrders.length === 0 ? (
              <p className="text-muted text-center py-3">No orders found</p>
            ) : (
              <div className="space-y-3">
                {statusOrders.map(o => (
                  <div key={o.order_id} className="border rounded p-3" style={{ background: '#f8f9fa' }}>
                    <div className="d-flex justify-content-between align-items-start mb-2">
                      <div>
                        <div className="fw-semibold">Order #{o.order_id}</div>
                        <small className="text-muted">{o.product_name || '—'}</small>
                      </div>
                      <StatusBadge status={o.order_status} />
                    </div>
                    <div className="row g-2 small mb-2">
                      <div className="col-6">
                        <div className="text-muted">Qty</div>
                        <div>{o.quantity} {o.unit}</div>
                      </div>
                      <div className="col-6">
                        <div className="text-muted">Order Date</div>
                        <div>{formatDateTime(o.order_date)}</div>
                      </div>
                    </div>
                    {/* Show dispatch details if available */}
                    {(o.order_status === 'DISPATCHED' || o.dispatch_vehicle_number || o.dispatch?.dispatch_vehicle_number) && (
                      <div className="border-top pt-2 mt-2 small" style={{ background: '#e7f3ff', padding: '8px', borderRadius: '4px' }}>
                        <div className="fw-semibold mb-1">🚛 Dispatch Info</div>
                        <div className="row g-2">
                          <div className="col-6">
                            <span className="text-muted">Vehicle:</span> <strong>{o.dispatch_vehicle_number || o.dispatch?.dispatch_vehicle_number || '—'}</strong>
                          </div>
                          <div className="col-6">
                            <span className="text-muted">Driver:</span> {o.dispatch_driver_phone || o.dispatch?.driver_phone ? (
                              <a href={'tel:' + (o.dispatch_driver_phone || o.dispatch?.driver_phone)} title="Call driver">
                                📞 {o.dispatch_driver_phone || o.dispatch?.driver_phone}
                              </a>
                            ) : (
                              <strong>—</strong>
                            )}
                          </div>
                          <div className="col-6">
                            <span className="text-muted">Bilty:</span> <strong>{o.bilty_number || o.dispatch?.bilty_number || '—'}</strong>
                          </div>
                          <div className="col-6">
                            <span className="text-muted">Dispatched:</span> {o.dispatch_created_at ? formatDateTime(o.dispatch_created_at) : (o.dispatch?.created_at ? formatDateTime(o.dispatch.created_at) : '—')}
                          </div>
                        </div>
                      </div>
                    )}
                    <div className="mt-2 text-end">
                      <button className="btn btn-sm btn-primary" onClick={() => onViewOrder(o)} title="View full order details">
                        👁️ View Details
                      </button>
                    </div>
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  );
}

function App() {
  const [orders, setOrders] = useState([]);
  const [loading, setLoading] = useState(true);
  const [search, setSearch] = useState('');
  const [statusFilter, setStatusFilter] = useState('ALL');
  const [startDate, setStartDate] = useState('');
  const [endDate, setEndDate] = useState('');

  const [refreshing, setRefreshing] = useState(false);
  const esRef = useRef(null);
  const retryRef = useRef(null);
  const [selectedOrderDetail, setSelectedOrderDetail] = useState(null);
  const [showDetailModal, setShowDetailModal] = useState(false);
  const [selectedStatusFilter, setSelectedStatusFilter] = useState(null);
  const [showStatusDealers, setShowStatusDealers] = useState(false);
  const [selectedStatusDealerId, setSelectedStatusDealerId] = useState(null);

  const getDefaultDates = () => {
    const end = new Date();
    const start = new Date();
    start.setDate(start.getDate() - 2);
    return {
      start: start.toISOString().slice(0, 10),
      end: end.toISOString().slice(0, 10),
    };
  };

  const load = async (dateFilters = {}) => {
    setLoading(true);
    try {
      const params = new URLSearchParams();
      const effectiveStartDate = dateFilters.startDate ?? startDate;
      const effectiveEndDate = dateFilters.endDate ?? endDate;
      if (effectiveStartDate) params.set('startDate', effectiveStartDate);
      if (effectiveEndDate) params.set('endDate', effectiveEndDate);
      const r = await fetch(`/api/sales/orders?${params.toString()}`, { credentials: 'include' });
      if (!r.ok) throw new Error(await r.text());
      setOrders(await r.json());
    } catch (e) {
      console.error(e.message);
    } finally {
      setLoading(false);
    }
  };

  useEffect(() => {
    const defaults = getDefaultDates();
    setStartDate(defaults.start);
    setEndDate(defaults.end);
    // Load immediately with the default dates
    setLoading(true);
    fetch(`/api/sales/orders?startDate=${defaults.start}&endDate=${defaults.end}`, { credentials: 'include' })
      .then(r => r.ok ? r.json() : Promise.reject(new Error(r.statusText)))
      .then(setOrders)
      .catch(e => console.error(e.message))
      .finally(() => setLoading(false));
  }, []);

  // SSE listener for real-time order status updates
  useEffect(() => {
    function connect() {
      const es = new EventSource('/api/orders/events', { withCredentials: true });
      esRef.current = es;
      es.addEventListener('order-status-changed', () => {
        setRefreshing(true);
        load().finally(() => setRefreshing(false));
      });
      es.onerror = () => {
        es.close();
        esRef.current = null;
        retryRef.current = setTimeout(connect, 3000);
      };
    }
    connect();
    return () => { esRef.current?.close(); clearTimeout(retryRef.current); };
  }, []);

  const applyDateFilter = () => {
    if (startDate && endDate && startDate > endDate) {
      alert('Start Date cannot be later than End Date.');
      return;
    }
    load();
  };

  const resetDateFilter = () => {
    const d = getDefaultDates();
    setStartDate(d.start);
    setEndDate(d.end);
    load({ startDate: d.start, endDate: d.end });
  };

  const counts = {
    total: orders.length,
    orderPlaced: orders.filter(o => o.order_status === 'ORDER_PLACED').length,
    accepted: orders.filter(o => o.order_status === 'ACCEPTED').length,
    dispatched: orders.filter(o => o.order_status === 'DISPATCHED').length,
    onHold: orders.filter(o => o.order_status === 'ON_HOLD').length,
  };

  const filtered = orders.filter(o => {
    const matchSearch = (o.product_name + ' ' + o.delivery_location + ' ' + o.order_id)
      .toLowerCase().includes(search.toLowerCase());
    const matchStatus = statusFilter === 'ALL' || o.order_status === statusFilter;
    return matchSearch && matchStatus;
  });

  return (
    <div>
      {refreshing && (
        <div style={{
          position: 'fixed', top: 0, left: 0, right: 0, zIndex: 9999,
          backgroundColor: '#0d6efd', color: '#fff',
          textAlign: 'center', padding: '4px 0',
          fontSize: '0.85rem', fontWeight: 500
        }}>
          Refreshing orders...
        </div>
      )}

      {/* Status Dealers Modal */}
      {showStatusDealers && selectedStatusFilter && (
        <StatusDealersModal
          orders={orders}
          status={selectedStatusFilter}
          onSelectDealer={dealerId => {
            setSelectedStatusDealerId(dealerId);
            setShowStatusDealers(false);
          }}
          onClose={() => setShowStatusDealers(false)}
        />
      )}

      {/* Status Orders Modal */}
      {selectedStatusDealerId && selectedStatusFilter && (
        <StatusOrdersModal
          orders={orders}
          status={selectedStatusFilter}
          dealerId={selectedStatusDealerId}
          onClose={() => setSelectedStatusDealerId(null)}
          onBack={() => {
            setSelectedStatusDealerId(null);
            setShowStatusDealers(true);
          }}
          onViewOrder={order => {
            setSelectedOrderDetail(order);
            setShowDetailModal(true);
            setSelectedStatusDealerId(null);
          }}
        />
      )}

      {/* Summary Cards - Clickable */}
      <div className="row mb-3">
        <div className="col-6 col-md-2 mb-3">
          <div
            className={`card border-0 shadow-sm h-100 count-card ${counts.total === 0 ? 'disabled' : ''}`}
            style={{ borderLeft: '4px solid #0d6efd' }}
            onClick={() => { if (counts.total > 0) { setSelectedStatusFilter('TOTAL'); setShowStatusDealers(true); } }}
          >
            <div className="card-body p-3">
              <div className="text-muted small mb-1">Total</div>
              <div className="fs-5 fw-bold">{counts.total}</div>
            </div>
          </div>
        </div>
        <div className="col-6 col-md-2 mb-3">
          <div
            className={`card border-0 shadow-sm h-100 count-card ${counts.orderPlaced === 0 ? 'disabled' : ''}`}
            style={{ borderLeft: '4px solid #fd7e14' }}
            onClick={() => { if (counts.orderPlaced > 0) { setSelectedStatusFilter('ORDER_PLACED'); setShowStatusDealers(true); } }}
          >
            <div className="card-body p-3">
              <div className="text-muted small mb-1">Placed</div>
              <div className="fs-5 fw-bold">{counts.orderPlaced}</div>
            </div>
          </div>
        </div>
        <div className="col-6 col-md-2 mb-3">
          <div
            className={`card border-0 shadow-sm h-100 count-card ${counts.accepted === 0 ? 'disabled' : ''}`}
            style={{ borderLeft: '4px solid #0dcaf0' }}
            onClick={() => { if (counts.accepted > 0) { setSelectedStatusFilter('ACCEPTED'); setShowStatusDealers(true); } }}
          >
            <div className="card-body p-3">
              <div className="text-muted small mb-1">Accepted</div>
              <div className="fs-5 fw-bold">{counts.accepted}</div>
            </div>
          </div>
        </div>
        <div className="col-6 col-md-2 mb-3">
          <div
            className={`card border-0 shadow-sm h-100 count-card ${counts.dispatched === 0 ? 'disabled' : ''}`}
            style={{ borderLeft: '4px solid #198754' }}
            onClick={() => { if (counts.dispatched > 0) { setSelectedStatusFilter('DISPATCHED'); setShowStatusDealers(true); } }}
          >
            <div className="card-body p-3">
              <div className="text-muted small mb-1">Dispatched</div>
              <div className="fs-5 fw-bold">{counts.dispatched}</div>
            </div>
          </div>
        </div>
        <div className="col-6 col-md-2 mb-3">
          <div
            className={`card border-0 shadow-sm h-100 count-card ${counts.onHold === 0 ? 'disabled' : ''}`}
            style={{ borderLeft: '4px solid #e57373' }}
            onClick={() => { if (counts.onHold > 0) { setSelectedStatusFilter('ON_HOLD'); setShowStatusDealers(true); } }}
          >
            <div className="card-body p-3">
              <div className="text-muted small mb-1">On Hold</div>
              <div className="fs-5 fw-bold">{counts.onHold}</div>
            </div>
          </div>
        </div>
      </div>

      {/* Orders Table */}
      <div className="card shadow-sm">
        <div className="card-header bg-white py-3">
          <h5 className="mb-0 fw-semibold">📊 All Orders (Read-Only)</h5>
        </div>
        <div className="card-body">
          <div className="row mb-3 g-2">
            <div className="col-md-3">
              <input className="form-control" placeholder="Search by product, order ID…"
                value={search} onChange={e => setSearch(e.target.value)} />
            </div>
            <div className="col-md-2">
              <input
                type="date"
                className="form-control"
                value={startDate}
                onChange={e => setStartDate(e.target.value)}
                aria-label="Start Date"
              />
            </div>
            <div className="col-md-2">
              <input
                type="date"
                className="form-control"
                value={endDate}
                onChange={e => setEndDate(e.target.value)}
                aria-label="End Date"
              />
            </div>
            <div className="col-md-2">
              <select className="form-select" value={statusFilter} onChange={e => setStatusFilter(e.target.value)}>
                <option value="ALL">All Statuses</option>
                {Object.entries(STATUS_CONFIG).map(([k, v]) =>
                  <option key={k} value={k}>{v.text}</option>
                )}
              </select>
            </div>
            <div className="col-md-2 d-flex gap-2">
              <button className="btn btn-outline-primary w-100" onClick={applyDateFilter}>
                Load
              </button>
              <button className="btn btn-outline-secondary" onClick={resetDateFilter} title="Reset to last 2 days">
                Reset
              </button>
            </div>
            <div className="col-12">
              <small className="text-muted">
                Showing orders from the last 2 days. Select a start & end date above and click <strong>Load</strong> to view other dates.
              </small>
            </div>
          </div>

          {loading ? (
            <div className="text-center py-5">
              <div className="spinner-border text-primary"></div>
              <p className="text-muted mt-2">Loading orders…</p>
            </div>
          ) : filtered.length === 0 ? (
            <div className="text-center text-muted py-5">No orders found</div>
          ) : (
            <div className="table-responsive">
              <table className="table table-hover table-bordered align-middle mb-0" style={{ fontSize: '0.9rem' }}>
                <thead className="table-light">
                  <tr>
                    <th style={{ width: 80 }}>Order</th>
                    <th>Dealer</th>
                    <th>Product</th>
                    <th style={{ width: 90 }}>Qty</th>
                    <th>Party</th>
                    <th style={{ width: 100 }}>Order Date</th>
                    <th style={{ width: 90 }}>⏱️ Time</th>
                    <th style={{ width: 120, textAlign: 'center' }}>Status</th>
                    <th style={{ width: 120, textAlign: 'center' }}>Action</th>
                  </tr>
                </thead>
                <tbody>
                  {filtered.map(o => (
                    <tr key={o.order_id} style={{ background: (o.order_status === 'DISPATCHED' || o.dispatch_vehicle_number || o.dispatch?.dispatch_vehicle_number) ? '#f0f8ff' : 'transparent' }}>
                      <td className="fw-semibold text-primary">#{o.order_id}</td>
                      <td className="text-muted small">{o.dealer_name || '—'}</td>
                      <td>{o.product_name}</td>
                      <td>{o.quantity} {o.unit}</td>
                      <td>{o.party_name || <span className="text-muted">—</span>}</td>
                      <td className="small">{formatDateTime(o.order_date)}</td>
                      <td className="text-center fw-semibold" title="Execution time since order placed">
                        {calculateExecutionTime(o.order_date)}
                      </td>
                      <td className="text-center">
                        <div>
                          <StatusBadge status={o.order_status} />
                          {(o.order_status === 'DISPATCHED' || o.dispatch_vehicle_number || o.dispatch?.dispatch_vehicle_number) && (
                            <div className="small mt-1" title="Dispatch details available">
                              🚛 {o.dispatch_vehicle_number || o.dispatch?.dispatch_vehicle_number || 'Dispatched'}
                            </div>
                          )}
                        </div>
                      </td>
                      <td className="text-center">
                        <div className="btn-group btn-group-sm flex-wrap" role="group">
                          <button className="btn btn-outline-primary" onClick={() => { setSelectedOrderDetail(o); setShowDetailModal(true); }} title="View order details (including dispatch info)">
                            👁️ View
                          </button>
                          {(o.dispatch && o.dispatch.driver_phone || o.dispatch_driver_phone || o.dispatch?.driver_phone) && (
                            <a
                              className="btn btn-outline-success"
                              href={`/tracking?driver=${encodeURIComponent(o.dispatch?.driver_phone || o.dispatch_driver_phone || o.dispatch?.dispatch?.driver_phone)}&order=${o.order_id}`}
                              title="View live tracking"
                            >
                              📍 Track
                            </a>
                          )}
                        </div>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </div>
      </div>

      {/* Order Detail Modal */}
      {showDetailModal && selectedOrderDetail && (
        <div style={{
          position: 'fixed', top: 0, left: 0, right: 0, bottom: 0,
          background: 'rgba(0,0,0,0.5)', zIndex: 10000,
          display: 'flex', alignItems: 'center', justifyContent: 'center'
        }}>
          <div style={{
            background: '#fff', borderRadius: 8, width: '95%', maxWidth: 800,
            maxHeight: '90vh', overflowY: 'auto', padding: 24
          }}>
            <div className="d-flex justify-content-between align-items-center mb-3">
              <div className="d-flex align-items-center gap-2">
                {selectedStatusDealerId && (
                  <button type="button" className="btn btn-sm btn-outline-secondary" onClick={() => setShowDetailModal(false)} title="Go back to orders list">
                    ← Back
                  </button>
                )}
                <h5 className="mb-0">📦 Order #{selectedOrderDetail.order_id} Details</h5>
              </div>
              <button type="button" className="btn-close" onClick={() => setShowDetailModal(false)}></button>
            </div>

            <div className="row g-3">
              <div className="col-12">
                <div className="card">
                  <div className="card-header bg-light">
                    <strong>Order Information</strong>
                  </div>
                  <div className="card-body">
                    <div className="row g-2">
                      <div className="col-md-6">
                        <div><strong>Order ID:</strong> {selectedOrderDetail.order_id}</div>
                        <div><strong>Date:</strong> {formatDateTime(selectedOrderDetail.order_date)}</div>
                        <div><strong>Status:</strong> <StatusBadge status={selectedOrderDetail.order_status} /></div>
                      </div>
                      <div className="col-md-6">
                        <div><strong>Dealer:</strong> {selectedOrderDetail.dealer_name}</div>
                        <div><strong>Party:</strong> {selectedOrderDetail.party_name || '—'}</div>
                        <div><strong>Quantity:</strong> {selectedOrderDetail.quantity} {selectedOrderDetail.unit}</div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              {(selectedOrderDetail.order_status === 'DISPATCHED' || selectedOrderDetail.dispatch_vehicle_number || selectedOrderDetail.dispatch?.dispatch_vehicle_number) && (
                <div className="col-12">
                  <div className="card border-success">
                    <div className="card-header bg-success text-white">
                      <strong>🚛 Dispatch Details</strong>
                    </div>
                    <div className="card-body">
                      <div className="row g-3">
                        <div className="col-md-6">
                          <div className="mb-2">
                            <div className="text-muted small fw-semibold">Vehicle Number</div>
                            <div className="fs-6 fw-bold">{selectedOrderDetail.dispatch_vehicle_number || selectedOrderDetail.dispatch?.dispatch_vehicle_number || '—'}</div>
                          </div>
                          <div className="mb-2">
                            <div className="text-muted small fw-semibold">Driver Name</div>
                            <div className="fw-semibold">{selectedOrderDetail.dispatch_driver_name || selectedOrderDetail.dispatch?.driver_name || '—'}</div>
                          </div>
                          <div className="mb-2">
                            <div className="text-muted small fw-semibold">Driver Phone</div>
                            <div>
                              {(selectedOrderDetail.dispatch_driver_phone || selectedOrderDetail.dispatch?.driver_phone) ? (
                                <a href={'tel:' + (selectedOrderDetail.dispatch_driver_phone || selectedOrderDetail.dispatch?.driver_phone)} className="btn btn-sm btn-outline-success">
                                  📞 {selectedOrderDetail.dispatch_driver_phone || selectedOrderDetail.dispatch?.driver_phone}
                                </a>
                              ) : (
                                <span className="text-muted">—</span>
                              )}
                            </div>
                          </div>
                        </div>
                        <div className="col-md-6">
                          <div className="mb-2">
                            <div className="text-muted small fw-semibold">Bilty Number</div>
                            <div className="fs-6 fw-bold">{selectedOrderDetail.bilty_number || selectedOrderDetail.dispatch?.bilty_number || '—'}</div>
                          </div>
                          <div className="mb-2">
                            <div className="text-muted small fw-semibold">Actual Loading Location</div>
                            <div className="fw-semibold">{selectedOrderDetail.actual_loading_location_code || selectedOrderDetail.dispatch?.actual_loading_location_code || selectedOrderDetail.actual_location_desc || '—'}</div>
                          </div>
                          <div className="mb-2">
                            <div className="text-muted small fw-semibold">Dispatched At</div>
                            <div>{selectedOrderDetail.dispatch_created_at ? formatDateTime(selectedOrderDetail.dispatch_created_at) : (selectedOrderDetail.dispatch?.created_at ? formatDateTime(selectedOrderDetail.dispatch.created_at) : '—')}</div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              )}

              <div className="col-12 text-end">
                {selectedStatusDealerId ? (
                  <>
                    <button className="btn btn-secondary me-2" onClick={() => setShowDetailModal(false)}>
                      ← Back to Orders
                    </button>
                    <button className="btn btn-outline-secondary" onClick={() => { setShowDetailModal(false); setSelectedStatusDealerId(null); setShowStatusDealers(true); }}>
                      ← Back to Dealers
                    </button>
                  </>
                ) : (
                  <button className="btn btn-secondary" onClick={() => setShowDetailModal(false)}>Close</button>
                )}
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}

ReactDOM.createRoot(document.getElementById('app-root')).render(<App />);
</script>
<%- include('../partials/footer') %>
