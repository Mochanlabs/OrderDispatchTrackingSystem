<%- include('../partials/header') %>
<script src="https://cdn.jsdelivr.net/npm/react@18/umd/react.development.js"></script>
<script src="https://cdn.jsdelivr.net/npm/react-dom@18/umd/react-dom.development.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@babel/standalone/babel.min.js"></script>

<nav aria-label="breadcrumb" class="mb-3">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
    <li class="breadcrumb-item active">Sales Dashboard</li>
  </ol>
</nav>
<div id="app-root"></div>

<script type="text/babel">
const { useState, useEffect } = React;

const STATUS_CONFIG = {
  ORDER_PLACED: { text: 'Order Placed', icon: '🕐', bg: '#fd7e14', tc: '#fff' },
  ACCEPTED:     { text: 'Accepted',     icon: '✅', bg: '#0dcaf0', tc: '#000' },
  DISPATCHED:   { text: 'Dispatched',   icon: '📦', bg: '#198754', tc: '#fff' },
  ON_HOLD:      { text: 'On Hold',      icon: '⏸️', bg: '#e57373', tc: '#fff' },
};

function formatDateTime(value) {
  if (!value) return '—';
  const dt = new Date(value);
  if (Number.isNaN(dt.getTime())) return value;
  return new Intl.DateTimeFormat('en-IN', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
    second: '2-digit',
    hour12: true,
  }).format(dt);
}

function calculateExecutionTime(orderDate) {
  if (!orderDate) return '—';
  const now = new Date();
  const order = new Date(orderDate);
  const diffMs = now - order;
  const diffMins = Math.floor(diffMs / 60000);
  const diffHours = Math.floor(diffMs / 3600000);
  const diffDays = Math.floor(diffMs / 86400000);

  if (diffDays > 0) return `${diffDays}d ${diffHours % 24}h`;
  if (diffHours > 0) return `${diffHours}h ${diffMins % 60}m`;
  return `${diffMins}m`;
}

function StatusBadge({ status }) {
  const cfg = STATUS_CONFIG[status] || { bg: '#6c757d', tc: '#fff', text: status };
  return (
    <span className="badge" style={{ background: cfg.bg, color: cfg.tc }}>
      {cfg.icon} {cfg.text}
    </span>
  );
}

function App() {
  const [orders, setOrders] = useState([]);
  const [loading, setLoading] = useState(true);
  const [search, setSearch] = useState('');
  const [statusFilter, setStatusFilter] = useState('ALL');
  const [startDate, setStartDate] = useState('');
  const [endDate, setEndDate] = useState('');

  const getDefaultDates = () => {
    const end = new Date();
    const start = new Date();
    start.setDate(start.getDate() - 2);
    return {
      start: start.toISOString().slice(0, 10),
      end: end.toISOString().slice(0, 10),
    };
  };

  const load = async (dateFilters = {}) => {
    setLoading(true);
    try {
      const params = new URLSearchParams();
      const effectiveStartDate = dateFilters.startDate ?? startDate;
      const effectiveEndDate = dateFilters.endDate ?? endDate;
      if (effectiveStartDate) params.set('startDate', effectiveStartDate);
      if (effectiveEndDate) params.set('endDate', effectiveEndDate);
      const r = await fetch(`/api/sales/orders?${params.toString()}`, { credentials: 'include' });
      if (!r.ok) throw new Error(await r.text());
      setOrders(await r.json());
    } catch (e) {
      console.error(e.message);
    } finally {
      setLoading(false);
    }
  };

  useEffect(() => {
    const defaults = getDefaultDates();
    setStartDate(defaults.start);
    setEndDate(defaults.end);
    // Load immediately with the default dates
    setLoading(true);
    fetch(`/api/sales/orders?startDate=${defaults.start}&endDate=${defaults.end}`, { credentials: 'include' })
      .then(r => r.ok ? r.json() : Promise.reject(new Error(r.statusText)))
      .then(setOrders)
      .catch(e => console.error(e.message))
      .finally(() => setLoading(false));
  }, []);

  const applyDateFilter = () => {
    if (startDate && endDate && startDate > endDate) {
      alert('Start Date cannot be later than End Date.');
      return;
    }
    load();
  };

  const resetDateFilter = () => {
    const d = getDefaultDates();
    setStartDate(d.start);
    setEndDate(d.end);
    load({ startDate: d.start, endDate: d.end });
  };

  const counts = {
    total: orders.length,
    orderPlaced: orders.filter(o => o.order_status === 'ORDER_PLACED').length,
    accepted: orders.filter(o => o.order_status === 'ACCEPTED').length,
    dispatched: orders.filter(o => o.order_status === 'DISPATCHED').length,
    onHold: orders.filter(o => o.order_status === 'ON_HOLD').length,
  };

  const filtered = orders.filter(o => {
    const matchSearch = (o.product_name + ' ' + o.delivery_location + ' ' + o.order_id)
      .toLowerCase().includes(search.toLowerCase());
    const matchStatus = statusFilter === 'ALL' || o.order_status === statusFilter;
    return matchSearch && matchStatus;
  });

  return (
    <div>
      {/* Summary Cards */}
      <div className="row mb-3">
        <div className="col-6 col-md-2 mb-3">
          <div className="card border-0 shadow-sm h-100" style={{ borderLeft: '4px solid #0d6efd' }}>
            <div className="card-body p-3">
              <div className="text-muted small mb-1">Total</div>
              <div className="fs-5 fw-bold">{counts.total}</div>
            </div>
          </div>
        </div>
        <div className="col-6 col-md-2 mb-3">
          <div className="card border-0 shadow-sm h-100" style={{ borderLeft: '4px solid #fd7e14' }}>
            <div className="card-body p-3">
              <div className="text-muted small mb-1">Placed</div>
              <div className="fs-5 fw-bold">{counts.orderPlaced}</div>
            </div>
          </div>
        </div>
        <div className="col-6 col-md-2 mb-3">
          <div className="card border-0 shadow-sm h-100" style={{ borderLeft: '4px solid #0dcaf0' }}>
            <div className="card-body p-3">
              <div className="text-muted small mb-1">Accepted</div>
              <div className="fs-5 fw-bold">{counts.accepted}</div>
            </div>
          </div>
        </div>
        <div className="col-6 col-md-2 mb-3">
          <div className="card border-0 shadow-sm h-100" style={{ borderLeft: '4px solid #198754' }}>
            <div className="card-body p-3">
              <div className="text-muted small mb-1">Dispatched</div>
              <div className="fs-5 fw-bold">{counts.dispatched}</div>
            </div>
          </div>
        </div>
        <div className="col-6 col-md-2 mb-3">
          <div className="card border-0 shadow-sm h-100" style={{ borderLeft: '4px solid #e57373' }}>
            <div className="card-body p-3">
              <div className="text-muted small mb-1">On Hold</div>
              <div className="fs-5 fw-bold">{counts.onHold}</div>
            </div>
          </div>
        </div>
      </div>

      {/* Orders Table */}
      <div className="card shadow-sm">
        <div className="card-header bg-white py-3">
          <h5 className="mb-0 fw-semibold">📊 All Orders (Read-Only)</h5>
        </div>
        <div className="card-body">
          <div className="row mb-3 g-2">
            <div className="col-md-3">
              <input className="form-control" placeholder="Search by product, order ID…"
                value={search} onChange={e => setSearch(e.target.value)} />
            </div>
            <div className="col-md-2">
              <input
                type="date"
                className="form-control"
                value={startDate}
                onChange={e => setStartDate(e.target.value)}
                aria-label="Start Date"
              />
            </div>
            <div className="col-md-2">
              <input
                type="date"
                className="form-control"
                value={endDate}
                onChange={e => setEndDate(e.target.value)}
                aria-label="End Date"
              />
            </div>
            <div className="col-md-2">
              <select className="form-select" value={statusFilter} onChange={e => setStatusFilter(e.target.value)}>
                <option value="ALL">All Statuses</option>
                {Object.entries(STATUS_CONFIG).map(([k, v]) =>
                  <option key={k} value={k}>{v.text}</option>
                )}
              </select>
            </div>
            <div className="col-md-2 d-flex gap-2">
              <button className="btn btn-outline-primary w-100" onClick={applyDateFilter}>
                Load
              </button>
              <button className="btn btn-outline-secondary" onClick={resetDateFilter} title="Reset to last 2 days">
                Reset
              </button>
            </div>
            <div className="col-12">
              <small className="text-muted">
                Showing orders from the last 2 days. Select a start & end date above and click <strong>Load</strong> to view other dates.
              </small>
            </div>
          </div>

          {loading ? (
            <div className="text-center py-5">
              <div className="spinner-border text-primary"></div>
              <p className="text-muted mt-2">Loading orders…</p>
            </div>
          ) : filtered.length === 0 ? (
            <div className="text-center text-muted py-5">No orders found</div>
          ) : (
            <div className="table-responsive">
              <table className="table table-hover table-bordered align-middle mb-0" style={{ fontSize: '0.9rem' }}>
                <thead className="table-light">
                  <tr>
                    <th style={{ width: 80 }}>Order</th>
                    <th>Dealer</th>
                    <th>Product</th>
                    <th style={{ width: 90 }}>Qty</th>
                    <th>Party</th>
                    <th style={{ width: 100 }}>Order Date</th>
                    <th style={{ width: 90 }}>⏱️ Time</th>
                    <th style={{ width: 120, textAlign: 'center' }}>Status</th>
                    <th style={{ width: 120, textAlign: 'center' }}>Action</th>
                  </tr>
                </thead>
                <tbody>
                  {filtered.map(o => (
                    <tr key={o.order_id}>
                      <td className="fw-semibold text-primary">#{o.order_id}</td>
                      <td className="text-muted small">{o.dealer_name || '—'}</td>
                      <td>{o.product_name}</td>
                      <td>{o.quantity} {o.unit}</td>
                      <td>{o.party_name || <span className="text-muted">—</span>}</td>
                      <td className="small">{formatDateTime(o.order_date)}</td>
                      <td className="text-center fw-semibold" title="Execution time since order placed">
                        {calculateExecutionTime(o.order_date)}
                      </td>
                      <td className="text-center"><StatusBadge status={o.order_status} /></td>
                      <td className="text-center">
                        {o.dispatch && o.dispatch.driver_phone && (
                          <a
                            className="btn btn-outline-success btn-sm"
                            href={`/tracking?driver=${encodeURIComponent(o.dispatch.driver_phone)}&order=${o.order_id}`}
                            title="View live tracking"
                          >
                            📍 Track
                          </a>
                        )}
                        {(!o.dispatch || !o.dispatch.driver_phone) && (
                          <span className="text-muted small">—</span>
                        )}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </div>
      </div>
    </div>
  );
}

ReactDOM.createRoot(document.getElementById('app-root')).render(<App />);
</script>
<%- include('../partials/footer') %>
